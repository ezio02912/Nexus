POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
RABBITMQ_DEFAULT_USER=nexus
RABBITMQ_DEFAULT_PASS=nexus_dev_password
MINIO_ROOT_USER=nexus
MINIO_ROOT_PASSWORD=nexus_dev_password

# Google OAuth (web-tenant + identity-service)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP / Mailpit (notification-service)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_ADDRESS=noreply@nexus.local
SMTP_FROM_NAME=Nexus Platform
SMTP_USE_SSL=false

# Internal service-to-service key (tenant-service + identity-service)
NEXUS_INTERNAL_API_KEY=nexus-internal-dev-key

# Tenant portal URL (email templates + worker)
TENANT_PORTAL_URL=http://localhost:7101/login
