@page "/audit"
@inject CoreApiClient Api
@inject DialogService DialogService
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Nhật ký</PageTitle>

<section class="page-header">
    <div>
        <h1>Nhật ký</h1>
        <p>Xem các bản ghi nhật ký và tạo bản ghi kiểm thử thủ công.</p>
    </div>
</section>

<Card HeaderText="Bản ghi nhật ký" IsShadow="true">
    <BodyTemplate>
        <Table @ref="_table" TItem="AuditLogEntry" OnQueryAsync="OnQueryAsync"
               IsPagination="true" PageItemsSource="@_pageItems" IsStriped="true" IsBordered="true"
               ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="false"
               ShowSearch="true" ShowSearchText="true" ShowRefresh="true">
            <TableToolbarTemplate>
                <TableToolbarButton TItem="AuditLogEntry" Color="Color.Primary" Icon="fa-solid fa-plus"
                                    Text="Tạo bản ghi thử" OnClickCallback="ShowCreateAsync" />
            </TableToolbarTemplate>
            <TableColumns>
                <TableColumn @bind-Field="@context.OccurredAt" Text="Thời gian" Sortable="true">
                    <Template Context="v">@v.Row.OccurredAt.ToLocalTime().ToString("g")</Template>
                </TableColumn>
                <TableColumn @bind-Field="@context.ServiceName" Text="Dịch vụ" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.EntityName" Text="Thực thể" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.Action" Text="Hành động" Sortable="true" />
                <TableColumn @bind-Field="@context.Summary" Text="Tóm tắt" Searchable="true" />
            </TableColumns>
        </Table>
    </BodyTemplate>
</Card>

@code {
    private Table<AuditLogEntry>? _table;
    private static readonly int[] _pageItems = [10, 20, 50];

    private async Task<QueryData<AuditLogEntry>> OnQueryAsync(QueryPageOptions options)
    {
        var all = await LoadAsync();
        return TableQuery.Apply(all, options);
    }

    private async Task<List<AuditLogEntry>> LoadAsync()
    {
        try
        {
            return (await Api.GetAuditLogsAsync())?.Items.ToList() ?? [];
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            return [];
        }
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.QueryAsync();
        }
    }

    // --- Create test audit entry modal -----------------------------------
    private Task ShowCreateAsync(IEnumerable<AuditLogEntry> _)
    {
        var model = new AuditCreateModel();
        var option = new EditDialogOption<AuditCreateModel>
        {
            Title = "Tạo bản ghi nhật ký thử",
            Model = model,
            Size = Size.Small,
            ItemsPerRow = 1,
            ShowLoading = true,
            SaveButtonText = "Lưu",
            CloseButtonText = "Đóng",
            DialogBodyTemplate = CreateBody,
            OnEditAsync = async _ =>
            {
                try
                {
                    await Api.CreateAuditLogAsync(new CreateAuditLogRequest(null, null, model.ServiceName, model.EntityName, null, 4, model.Summary, Guid.NewGuid().ToString("N")));
                    await ToastService.Success("Thành công", "Đã tạo bản ghi nhật ký.");
                    await ReloadTableAsync();
                    return true;
                }
                catch (Exception ex)
                {
                    await ShowErrorAsync(ex);
                    return false;
                }
            }
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<AuditCreateModel> CreateBody => model =>
    @<div class="row g-3">
        <div class="col-12">
            <BootstrapInput @bind-Value="model.ServiceName" DisplayText="Dịch vụ" ShowLabel="true" />
        </div>
        <div class="col-12">
            <BootstrapInput @bind-Value="model.EntityName" DisplayText="Thực thể" ShowLabel="true" />
        </div>
        <div class="col-12">
            <BootstrapInput @bind-Value="model.Summary" DisplayText="Tóm tắt" ShowLabel="true" />
        </div>
    </div>;

    private Task ShowErrorAsync(Exception ex) => SwalService.Show(new SwalOption
    {
        Category = SwalCategory.Error,
        Title = "Đã xảy ra lỗi",
        Content = ex.Message
    });

    private sealed class AuditCreateModel
    {
        [Required(ErrorMessage = "Vui lòng nhập tên dịch vụ")]
        public string ServiceName { get; set; } = "web-admin";

        [Required(ErrorMessage = "Vui lòng nhập tên thực thể")]
        public string EntityName { get; set; } = "SmokeTest";

        public string Summary { get; set; } = "Manual audit check";
    }
}
