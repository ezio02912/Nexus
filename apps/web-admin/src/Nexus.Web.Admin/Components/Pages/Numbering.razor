@page "/numbering"
@inject CoreApiClient Api
@inject TenantLookupService TenantLookup
@inject DialogService DialogService
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Đánh số</PageTitle>

<section class="page-header">
    <div>
        <h1>Đánh số</h1>
        <p>Cấp số chứng từ theo khách thuê, mô-đun, loại và kỳ.</p>
    </div>
</section>

<Card HeaderText="Danh sách chuỗi số" IsShadow="true">
    <BodyTemplate>
        <Table @ref="_table" TItem="NumberSequenceDto" OnQueryAsync="OnQueryAsync"
               IsPagination="true" PageItemsSource="@_pageItems" IsStriped="true" IsBordered="true"
               ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="false"
               ShowSearch="true" ShowSearchText="true" ShowRefresh="true">
            <TableToolbarTemplate>
                <TableToolbarButton TItem="NumberSequenceDto" Color="Color.Primary" Icon="fa-solid fa-hashtag"
                                    Text="Sinh số" OnClickCallback="ShowNextNumberAsync" />
            </TableToolbarTemplate>
            <TableColumns>
                <TableColumn @bind-Field="@context.Key" Text="Khóa" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.CurrentValue" Text="Giá trị hiện tại" Sortable="true" />
            </TableColumns>
        </Table>
    </BodyTemplate>
</Card>

@code {
    private Table<NumberSequenceDto>? _table;
    private List<SelectedItem> _tenantOptions = [];
    private static readonly int[] _pageItems = [10, 20, 50];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Tenant is optional when generating a document number.
            _tenantOptions = await TenantLookup.GetOptionsAsync(includeEmpty: true, forceRefresh: true);
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private async Task<QueryData<NumberSequenceDto>> OnQueryAsync(QueryPageOptions options)
    {
        var all = await LoadAsync();
        return TableQuery.Apply(all, options);
    }

    private async Task<List<NumberSequenceDto>> LoadAsync()
    {
        try
        {
            return (await Api.GetNumberSequencesAsync())?.ToList() ?? [];
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            return [];
        }
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.QueryAsync();
        }
    }

    // --- Generate next number modal --------------------------------------
    private Task ShowNextNumberAsync(IEnumerable<NumberSequenceDto> _)
    {
        var model = new NextNumberModel();
        var option = new EditDialogOption<NextNumberModel>
        {
            Title = "Cấp số tiếp theo",
            Model = model,
            Size = Size.Medium,
            ItemsPerRow = 1,
            ShowLoading = true,
            SaveButtonText = "Sinh số",
            CloseButtonText = "Đóng",
            DialogBodyTemplate = NextNumberBody,
            OnEditAsync = async _ =>
            {
                try
                {
                    Guid? tenantId = Guid.TryParse(model.TenantId, out var parsed) ? parsed : null;
                    var result = await Api.GetNextNumberAsync(new NextNumberRequest(tenantId, model.Module, model.DocumentType, model.Prefix, 5, model.Period));
                    await ToastService.Success("Đã sinh số", $"Số tiếp theo: {result?.Number}");
                    await ReloadTableAsync();
                    return true;
                }
                catch (Exception ex)
                {
                    await ShowErrorAsync(ex);
                    return false;
                }
            }
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<NextNumberModel> NextNumberBody => model =>
    @<div class="row g-3">
        <div class="col-12">
            <Select TValue="string" @bind-Value="model.TenantId" Items="_tenantOptions"
                    DisplayText="Mã khách thuê" ShowLabel="true" ShowSearch="true" PlaceHolder="Chọn khách thuê" />
        </div>
        <div class="col-md-6">
            <Select TValue="string" @bind-Value="model.Module" Items="UiCatalogs.Modules" DisplayText="Mô-đun" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.DocumentType" DisplayText="Loại chứng từ" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.Prefix" DisplayText="Tiền tố" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.Period" DisplayText="Kỳ" ShowLabel="true" />
        </div>
    </div>;

    private Task ShowErrorAsync(Exception ex) => SwalService.Show(new SwalOption
    {
        Category = SwalCategory.Error,
        Title = "Đã xảy ra lỗi",
        Content = ex.Message
    });

    private sealed class NextNumberModel
    {
        public string TenantId { get; set; } = "";
        public string Module { get; set; } = "INVOICE";

        [Required(ErrorMessage = "Vui lòng nhập loại chứng từ")]
        public string DocumentType { get; set; } = "SalesInvoice";

        [Required(ErrorMessage = "Vui lòng nhập tiền tố")]
        public string Prefix { get; set; } = "INV-";

        public string Period { get; set; } = DateTimeOffset.UtcNow.ToString("yyyyMM");
    }
}
