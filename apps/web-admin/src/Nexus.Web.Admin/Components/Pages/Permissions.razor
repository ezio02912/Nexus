@page "/permissions"
@inject CoreApiClient Api
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Phân quyền</PageTitle>

<section class="page-header">
    <div>
        <h1>Phân quyền</h1>
        <p>Quản lý quyền được cấp cho từng vai trò.</p>
    </div>
</section>

<div class="work-surface">
    <Card HeaderText="Gán quyền vai trò" IsShadow="true">
        <BodyTemplate>
            <Select TValue="string" Value="_roleName" ValueChanged="OnRoleChangedAsync" Items="UiCatalogs.Roles"
                    DisplayText="Tên vai trò" ShowLabel="true" class="mb-2" />
            <div class="form-text mb-3">Khóa vai trò: <code>@_roleName.ToUpperInvariant()</code></div>
            <div class="d-flex gap-2 flex-wrap">
                <Button Text="Lưu quyền" Icon="fa-solid fa-floppy-disk" Color="Color.Primary"
                        IsAsync="true" OnClick="SaveAsync" IsDisabled="_loadingRole" />
            </div>
        </BodyTemplate>
    </Card>

    <Card HeaderText="Danh mục quyền" IsShadow="true">
        <BodyTemplate>
            <div class="admin-permission-toolbar">
                <BootstrapInput @bind-Value="_filter" DisplayText="Lọc quyền" ShowLabel="false"
                                PlaceHolder="Lọc quyền" />
            </div>

            @if (_loading || _loadingRole)
            {
                <div class="app-loading py-4">
                    <Spinner Color="Color.Primary" />
                    <span class="app-loading-text">@(_loading ? "Đang tải danh mục quyền..." : "Đang tải quyền vai trò...")</span>
                </div>
            }
            else if (PermissionGroups.Count == 0)
            {
                <div class="text-muted py-3">Không có quyền phù hợp với bộ lọc.</div>
            }
            else
            {
                @foreach (var group in PermissionGroups)
                {
                    <section class="admin-permission-group">
                        <div class="admin-permission-group-header">
                            <h3>@group.ServiceKey</h3>
                            <Checkbox TValue="bool"
                                      DisplayText="Chọn tất cả"
                                      Value="@IsGroupFullySelected(group.ServiceKey)"
                                      OnStateChanged="@((state, _) => ToggleGroupAsync(group.ServiceKey, state))" />
                        </div>
                        <div class="admin-permission-catalog">
                            @foreach (var permission in group.Permissions)
                            {
                                <label class="admin-permission-item">
                                    <Checkbox TValue="bool"
                                              Value="@_selectedPermissions.Contains(permission)"
                                              OnStateChanged="@((state, _) => TogglePermissionAsync(permission, state))" />
                                    <code>@permission</code>
                                </label>
                            }
                        </div>
                    </section>
                }
            }
        </BodyTemplate>
    </Card>
</div>

@code {
    private List<string> _catalog = [];
    private HashSet<string> _selectedPermissions = new(StringComparer.OrdinalIgnoreCase);
    private string _roleName = "ADMIN";
    private string _filter = "";
    private bool _loading = true;
    private bool _loadingRole;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogAsync();
        await LoadRoleAsync();
    }

    private IReadOnlyList<PermissionGroupView> PermissionGroups =>
        _catalog
            .Where(MatchesFilter)
            .GroupBy(GetServiceKey)
            .OrderBy(g => g.Key)
            .Select(g => new PermissionGroupView(g.Key, g.OrderBy(x => x).ToList()))
            .ToList();

    private bool MatchesFilter(string permission) =>
        string.IsNullOrWhiteSpace(_filter)
        || permission.Contains(_filter, StringComparison.OrdinalIgnoreCase);

    private static string GetServiceKey(string permission)
    {
        var parts = permission.Split('.', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length >= 2 ? $"{parts[0]}.{parts[1]}" : parts[0];
    }

    private bool IsGroupFullySelected(string serviceKey) =>
        _catalog.Where(x => GetServiceKey(x) == serviceKey).All(x => _selectedPermissions.Contains(x));

    private async Task LoadCatalogAsync()
    {
        _loading = true;
        try
        {
            _catalog = (await Api.GetPermissionCatalogAsync())?.OrderBy(x => x).ToList() ?? [];
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            _catalog = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadRoleAsync()
    {
        _loadingRole = true;
        try
        {
            var result = await Api.GetRolePermissionsAsync(_roleName);
            _selectedPermissions = new HashSet<string>(result?.Permissions ?? [], StringComparer.OrdinalIgnoreCase);
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
        finally
        {
            _loadingRole = false;
        }
    }

    private async Task OnRoleChangedAsync(string roleName)
    {
        _roleName = roleName;
        await LoadRoleAsync();
    }

    private async Task SaveAsync()
    {
        try
        {
            var permissions = _selectedPermissions.OrderBy(x => x).ToArray();
            var result = await Api.UpdateRolePermissionsAsync(_roleName, new UpdateRolePermissionsRequest(permissions));
            await ToastService.Success("Đã lưu", $"Đã lưu {result?.Permissions.Count ?? 0} quyền cho {_roleName}.");
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private Task TogglePermissionAsync(string permission, CheckboxState state)
    {
        if (state == CheckboxState.Checked)
        {
            _selectedPermissions.Add(permission);
        }
        else
        {
            _selectedPermissions.Remove(permission);
        }

        return Task.CompletedTask;
    }

    private Task ToggleGroupAsync(string serviceKey, CheckboxState state)
    {
        var selectAll = state == CheckboxState.Checked;
        foreach (var permission in _catalog.Where(x => GetServiceKey(x) == serviceKey))
        {
            if (selectAll)
            {
                _selectedPermissions.Add(permission);
            }
            else
            {
                _selectedPermissions.Remove(permission);
            }
        }

        return Task.CompletedTask;
    }

    private Task ShowErrorAsync(Exception ex) => SwalService.Show(new SwalOption
    {
        Category = SwalCategory.Error,
        Title = "Đã xảy ra lỗi",
        Content = ex.Message
    });

    private sealed record PermissionGroupView(string ServiceKey, IReadOnlyList<string> Permissions);
}
