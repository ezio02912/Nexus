@page "/tenants"
@inject CoreApiClient Api

<PageTitle>Khách thuê</PageTitle>

<section class="page-header">
    <div>
        <h1>Khách thuê</h1>
        <p>Tạo khách thuê, đổi trạng thái, bật mô-đun và lưu cấu hình.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <Alert Color="@_messageColor" ShowDismiss="true" class="mb-3">@_message</Alert>
}

<div class="work-surface">
    <Card HeaderText="Tạo khách thuê" IsShadow="true">
        <BodyTemplate>
            <BootstrapInput @bind-Value="_tenantCode" DisplayText="Mã" ShowLabel="true" class="mb-2" />
            <BootstrapInput @bind-Value="_tenantName" DisplayText="Tên" ShowLabel="true" class="mb-3" />
            <Button Text="Tạo mới" Icon="fa-solid fa-plus" Color="Color.Success" IsAsync="true" OnClick="CreateAsync" />

            <hr />

            <h6 class="text-muted">Tham số thao tác</h6>
            <Select TValue="string" @bind-Value="_moduleCode" Items="UiCatalogs.Modules"
                    DisplayText="Mã mô-đun" ShowLabel="true" class="mb-2" />
            <BootstrapInput @bind-Value="_settingKey" DisplayText="Khóa cấu hình" ShowLabel="true" class="mb-2" />
            <BootstrapInput @bind-Value="_settingValue" DisplayText="Giá trị cấu hình" ShowLabel="true" />
        </BodyTemplate>
    </Card>

    <Card HeaderText="Danh sách khách thuê" IsShadow="true">
        <BodyTemplate>
            <Table @ref="_table" TItem="TenantDto" OnQueryAsync="OnQueryAsync"
                   IsPagination="true" PageItemsSource="@_pageItems" IsStriped="true" IsBordered="true"
                   ShowToolbar="true" ShowSearch="true" ShowSearchText="true" ShowDefaultButtons="false"
                   ShowExtendButtons="true" ExtendButtonColumnWidth="360" ShowRefresh="true">
                <TableColumns>
                    <TableColumn @bind-Field="@context.Code" Text="Mã" Sortable="true" Searchable="true" />
                    <TableColumn @bind-Field="@context.Name" Text="Tên" Sortable="true" Searchable="true" />
                    <TableColumn @bind-Field="@context.Status" Text="Trạng thái" Sortable="true" Searchable="true" />
                    <TableColumn @bind-Field="@context.Id" Text="Mô-đun đang bật" Sortable="false">
                        <Template Context="v">@EnabledModules(v.Row)</Template>
                    </TableColumn>
                </TableColumns>
                <RowButtonTemplate>
                    <TableCellButton Color="Color.Success" Icon="fa-solid fa-circle-check" Text="Kích hoạt"
                                     OnClick="() => ActivateAsync(context.Id)" />
                    <TableCellButton Color="Color.Warning" Icon="fa-solid fa-circle-pause" Text="Tạm ngưng"
                                     OnClick="() => SuspendAsync(context.Id)" />
                    <TableCellButton Color="Color.Info" Icon="fa-solid fa-toggle-on" Text="Bật mô-đun"
                                     OnClick="() => EnableModuleAsync(context.Id)" />
                    <TableCellButton Color="Color.Secondary" Icon="fa-solid fa-floppy-disk" Text="Lưu cấu hình"
                                     OnClick="() => SaveSettingAsync(context.Id)" />
                </RowButtonTemplate>
            </Table>
        </BodyTemplate>
    </Card>
</div>

@code {
    private Table<TenantDto>? _table;
    private string _tenantCode = "";
    private string _tenantName = "";
    private string _moduleCode = "CRM";
    private string _settingKey = "Timezone";
    private string _settingValue = "Asia/Bangkok";
    private string? _message;
    private Color _messageColor = Color.Primary;
    private static readonly int[] _pageItems = [10, 20, 50];

    private async Task<QueryData<TenantDto>> OnQueryAsync(QueryPageOptions options)
    {
        var all = await LoadAsync();
        return TableQuery.Apply(all, options);
    }

    private async Task<List<TenantDto>> LoadAsync()
    {
        try
        {
            var result = (await Api.GetTenantsAsync())?.Items.ToList() ?? [];
            return result;
        }
        catch (Exception ex)
        {
            SetError(ex.Message);
            return [];
        }
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.QueryAsync();
        }
    }

    private async Task CreateAsync()
    {
        try
        {
            await Api.CreateTenantAsync(new CreateTenantRequest(_tenantCode, _tenantName));
            _tenantCode = "";
            _tenantName = "";
            SetInfo("Đã tạo khách thuê.");
            await ReloadTableAsync();
        }
        catch (Exception ex)
        {
            SetError(ex.Message);
        }
    }

    private async Task ActivateAsync(Guid id)
    {
        await Api.ActivateTenantAsync(id);
        SetInfo("Đã kích hoạt khách thuê.");
        await ReloadTableAsync();
    }

    private async Task SuspendAsync(Guid id)
    {
        await Api.SuspendTenantAsync(id);
        SetInfo("Đã tạm ngưng khách thuê.");
        await ReloadTableAsync();
    }

    private async Task EnableModuleAsync(Guid id)
    {
        await Api.EnableTenantModuleAsync(id, new ChangeTenantModuleRequest(_moduleCode));
        SetInfo($"Đã bật mô-đun {_moduleCode}.");
        await ReloadTableAsync();
    }

    private async Task SaveSettingAsync(Guid id)
    {
        await Api.UpdateTenantSettingsAsync(id, new UpdateTenantSettingsRequest(new Dictionary<string, string> { [_settingKey] = _settingValue }));
        SetInfo("Đã lưu cấu hình.");
        await ReloadTableAsync();
    }

    private static string EnabledModules(TenantDto tenant)
        => string.Join(", ", tenant.Modules?.Where(x => x.IsEnabled).Select(x => x.ModuleCode) ?? Enumerable.Empty<string>());

    private void SetInfo(string text)
    {
        _message = text;
        _messageColor = Color.Success;
    }

    private void SetError(string text)
    {
        _message = text;
        _messageColor = Color.Danger;
    }
}
