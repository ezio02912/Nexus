@page "/users"
@inject CoreApiClient Api
@inject TenantLookupService TenantLookup
@inject DialogService DialogService
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Người dùng</PageTitle>

<section class="page-header">
    <div>
        <h1>Người dùng</h1>
        <p>Tạo người dùng cho khách thuê và kiểm tra đăng nhập.</p>
    </div>
</section>

<Card HeaderText="Danh sách người dùng" IsShadow="true">
    <BodyTemplate>
        <Table @ref="_table" TItem="UserDto" OnQueryAsync="OnQueryAsync"
               IsPagination="true" PageItemsSource="@_pageItems" IsStriped="true" IsBordered="true"
               ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
               ShowEditButton="false" ShowDeleteButton="false" ExtendButtonColumnWidth="130"
               ShowSearch="true" ShowSearchText="true" ShowRefresh="true">
            <TableToolbarTemplate>
                <TableToolbarButton TItem="UserDto" Color="Color.Primary" Icon="fa-solid fa-user-plus"
                                    Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                <TableToolbarButton TItem="UserDto" Color="Color.Info" Icon="fa-solid fa-key"
                                    Text="Đăng nhập thử" OnClickCallback="ShowLoginAsync" />
            </TableToolbarTemplate>
            <RowButtonTemplate>
                <TableCellButton Color="Color.Info" Icon="fa-solid fa-pen-to-square" Text="Sửa"
                                 OnClick="@(() => ShowEditAsync([context]))" />
                <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                 OnClick="@(() => DeleteSelectedAsync([context]))" />
            </RowButtonTemplate>
            <TableColumns>
                <TableColumn @bind-Field="@context.UserName" Text="Tên đăng nhập" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.Email" Text="Email" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.TenantId" Text="Khách thuê" Sortable="false">
                    <Template Context="v">@TenantLookup.Describe(v.Row.TenantId)</Template>
                </TableColumn>
                <TableColumn @bind-Field="@context.Id" Text="Vai trò" Sortable="false">
                    <Template Context="v">@RolesText(v.Row)</Template>
                </TableColumn>
            </TableColumns>
        </Table>
    </BodyTemplate>
</Card>

@code {
    private Table<UserDto>? _table;
    private List<SelectedItem> _tenantOptions = [];
    private static readonly int[] _pageItems = [10, 20, 50];

    protected override async Task OnInitializedAsync()
    {
        // Preload the tenant catalog so the dropdown shows codes and the table can
        // resolve tenant Ids to their code/name instead of showing a raw GUID.
        try
        {
            _tenantOptions = await TenantLookup.GetOptionsAsync(forceRefresh: true);
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private async Task<QueryData<UserDto>> OnQueryAsync(QueryPageOptions options)
    {
        var all = await LoadAsync();
        return TableQuery.Apply(all, options);
    }

    private async Task<List<UserDto>> LoadAsync()
    {
        try
        {
            return (await Api.GetUsersAsync())?.Items.ToList() ?? [];
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            return [];
        }
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.QueryAsync();
        }
    }

    // --- Create modal -----------------------------------------------------
    private Task ShowCreateAsync(IEnumerable<UserDto> _)
    {
        var model = new UserCreateModel();
        var option = new EditDialogOption<UserCreateModel>
        {
            Title = "Thêm người dùng",
            Model = model,
            Size = Size.Medium,
            ItemsPerRow = 1,
            ShowLoading = true,
            SaveButtonText = "Lưu",
            CloseButtonText = "Đóng",
            DialogBodyTemplate = CreateUserBody,
            OnEditAsync = async _ =>
            {
                if (!Guid.TryParse(model.TenantId, out var tenantId))
                {
                    await ToastService.Information("Thiếu thông tin", "Vui lòng chọn khách thuê.");
                    return false;
                }

                try
                {
                    await Api.CreateUserAsync(new CreateUserRequest(tenantId, model.UserName, model.Email, model.Password, [model.Role]));
                    await ToastService.Success("Thành công", "Đã tạo người dùng.");
                    await ReloadTableAsync();
                    return true;
                }
                catch (Exception ex)
                {
                    await ShowErrorAsync(ex);
                    return false;
                }
            }
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<UserCreateModel> CreateUserBody => model =>
    @<div class="row g-3">
        <div class="col-12">
            <Select TValue="string" @bind-Value="model.TenantId" Items="_tenantOptions"
                    DisplayText="Mã khách thuê" ShowLabel="true" ShowSearch="true" PlaceHolder="Chọn khách thuê" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.UserName" DisplayText="Tên đăng nhập" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.Email" DisplayText="Email" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapPassword @bind-Value="model.Password" DisplayText="Mật khẩu" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <Select TValue="string" @bind-Value="model.Role" Items="UiCatalogs.Roles" DisplayText="Vai trò" ShowLabel="true" />
        </div>
    </div>;

    // --- Login test modal -------------------------------------------------
    private Task ShowLoginAsync(IEnumerable<UserDto> _)
    {
        var model = new UserLoginModel();
        var option = new EditDialogOption<UserLoginModel>
        {
            Title = "Đăng nhập thử",
            Model = model,
            Size = Size.Small,
            ItemsPerRow = 1,
            ShowLoading = true,
            SaveButtonText = "Đăng nhập",
            CloseButtonText = "Đóng",
            DialogBodyTemplate = LoginBody,
            OnEditAsync = async _ =>
            {
                if (!Guid.TryParse(model.TenantId, out var tenantId))
                {
                    await ToastService.Information("Thiếu thông tin", "Vui lòng chọn khách thuê.");
                    return false;
                }

                try
                {
                    var result = await Api.LoginAsync(new LoginRequest(tenantId, model.UserName, model.Password));
                    if (result is null)
                    {
                        await ShowErrorAsync(new InvalidOperationException("Đăng nhập thất bại."));
                        return false;
                    }

                    await ToastService.Success("Đăng nhập thành công", $"Token hết hạn lúc {result.ExpiresAt:u}");
                    return true;
                }
                catch (Exception ex)
                {
                    await ShowErrorAsync(ex);
                    return false;
                }
            }
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<UserLoginModel> LoginBody => model =>
    @<div class="row g-3">
        <div class="col-12">
            <Select TValue="string" @bind-Value="model.TenantId" Items="_tenantOptions"
                    DisplayText="Mã khách thuê" ShowLabel="true" ShowSearch="true" PlaceHolder="Chọn khách thuê" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.UserName" DisplayText="Tên đăng nhập" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapPassword @bind-Value="model.Password" DisplayText="Mật khẩu" ShowLabel="true" />
        </div>
    </div>;

    // --- Edit (view-only until update API is available) -------------------
    private Task ShowEditAsync(IEnumerable<UserDto> rows)
    {
        var user = rows.FirstOrDefault();
        if (user is null)
        {
            return Task.CompletedTask;
        }

        var model = new UserViewModel
        {
            UserName = user.UserName,
            Email = user.Email,
            TenantName = TenantLookup.Describe(user.TenantId),
            Roles = RolesText(user)
        };

        var option = new EditDialogOption<UserViewModel>
        {
            Title = $"Người dùng: {user.UserName}",
            Model = model,
            Size = Size.Small,
            ItemsPerRow = 1,
            ShowLoading = false,
            SaveButtonText = "Đóng",
            CloseButtonText = "Huỷ",
            DialogBodyTemplate = ViewUserBody,
            OnEditAsync = _ => Task.FromResult(true)
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<UserViewModel> ViewUserBody => model =>
    @<div class="row g-3">
        <div class="col-12">
            <BootstrapInput Value="@model.UserName" DisplayText="Tên đăng nhập" ShowLabel="true" IsDisabled="true" />
        </div>
        <div class="col-12">
            <BootstrapInput Value="@model.Email" DisplayText="Email" ShowLabel="true" IsDisabled="true" />
        </div>
        <div class="col-12">
            <BootstrapInput Value="@model.TenantName" DisplayText="Khách thuê" ShowLabel="true" IsDisabled="true" />
        </div>
        <div class="col-12">
            <BootstrapInput Value="@model.Roles" DisplayText="Vai trò" ShowLabel="true" IsDisabled="true" />
        </div>
    </div>;

    // --- Delete -----------------------------------------------------------
    private async Task DeleteSelectedAsync(IEnumerable<UserDto> rows)
    {
        var list = rows?.ToList() ?? [];
        if (list.Count == 0)
        {
            await ToastService.Information("Chưa chọn", "Vui lòng chọn ít nhất một dòng để xoá.");
            return;
        }

        var confirmed = await SwalService.ShowModal(new SwalOption
        {
            Category = SwalCategory.Question,
            Title = "Xác nhận xoá",
            Content = list.Count == 1
                ? $"Bạn có chắc muốn xoá người dùng \"{list[0].UserName}\"?"
                : $"Bạn có chắc muốn xoá {list.Count} người dùng đã chọn?"
        });
        if (!confirmed)
        {
            return;
        }

        try
        {
            foreach (var user in list)
            {
                await Api.DeleteUserAsync(user.Id);
            }

            await ToastService.Success("Đã xoá", "Đã xoá người dùng đã chọn.");
            await ReloadTableAsync();
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private static string RolesText(UserDto user)
        => string.Join(", ", user.Roles ?? Array.Empty<string>());

    private Task ShowErrorAsync(Exception ex) => SwalService.Show(new SwalOption
    {
        Category = SwalCategory.Error,
        Title = "Đã xảy ra lỗi",
        Content = ex.Message
    });

    private sealed class UserCreateModel
    {
        public string TenantId { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập tên đăng nhập")]
        public string UserName { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập email")]
        [EmailAddress(ErrorMessage = "Email không hợp lệ")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập mật khẩu")]
        public string Password { get; set; } = "Password@123";

        public string Role { get; set; } = "ADMIN";
    }

    private sealed class UserLoginModel
    {
        public string TenantId { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập tên đăng nhập")]
        public string UserName { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập mật khẩu")]
        public string Password { get; set; } = "";
    }

    private sealed class UserViewModel
    {
        public string UserName { get; set; } = "";
        public string Email { get; set; } = "";
        public string TenantName { get; set; } = "";
        public string Roles { get; set; } = "";
    }
}
