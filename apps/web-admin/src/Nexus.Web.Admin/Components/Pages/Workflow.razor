@page "/workflow"
@inject CoreApiClient Api
@inject TenantLookupService TenantLookup
@inject DialogService DialogService
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Quy trình</PageTitle>

<section class="page-header">
    <div>
        <h1>Quy trình</h1>
        <p>Tạo định nghĩa quy trình và khởi tạo phiên phê duyệt.</p>
    </div>
</section>

<Card HeaderText="Danh sách định nghĩa" IsShadow="true">
    <BodyTemplate>
        <Table @ref="_table" TItem="WorkflowDefinitionRecord" OnQueryAsync="OnQueryAsync"
               IsPagination="true" PageItemsSource="@_pageItems" IsStriped="true" IsBordered="true"
               ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
               ShowEditButton="false" ShowDeleteButton="false" ExtendButtonColumnWidth="130"
               ShowSearch="true" ShowSearchText="true" ShowRefresh="true">
            <TableToolbarTemplate>
                <TableToolbarButton TItem="WorkflowDefinitionRecord" Color="Color.Primary" Icon="fa-solid fa-plus"
                                    Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                <TableToolbarButton TItem="WorkflowDefinitionRecord" Color="Color.Success" Icon="fa-solid fa-play"
                                    Text="Khởi tạo phiên" IsEnableWhenSelectedOneRow="true" OnClickCallback="StartInstanceAsync" />
            </TableToolbarTemplate>
            <RowButtonTemplate>
                <TableCellButton Color="Color.Info" Icon="fa-solid fa-pen-to-square" Text="Sửa"
                                 OnClick="@(() => ShowEditAsync([context]))" />
                <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                 OnClick="@(() => DeleteSelectedAsync([context]))" />
            </RowButtonTemplate>
            <TableColumns>
                <TableColumn @bind-Field="@context.Code" Text="Mã" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.Name" Text="Tên" Sortable="true" Searchable="true" />
                <TableColumn @bind-Field="@context.IsActive" Text="Các bước" Sortable="false">
                    <Template Context="v">@string.Join(" -> ", v.Row.Steps)</Template>
                </TableColumn>
            </TableColumns>
        </Table>
    </BodyTemplate>
</Card>

@code {
    private Table<WorkflowDefinitionRecord>? _table;
    private List<SelectedItem> _tenantOptions = [];
    private static readonly int[] _pageItems = [10, 20, 50];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Tenant is optional for a workflow definition, so allow an empty choice.
            _tenantOptions = await TenantLookup.GetOptionsAsync(includeEmpty: true, forceRefresh: true);
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private async Task<QueryData<WorkflowDefinitionRecord>> OnQueryAsync(QueryPageOptions options)
    {
        var all = await LoadAsync();
        return TableQuery.Apply(all, options);
    }

    private async Task<List<WorkflowDefinitionRecord>> LoadAsync()
    {
        try
        {
            return (await Api.GetWorkflowDefinitionsAsync())?.ToList() ?? [];
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            return [];
        }
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.QueryAsync();
        }
    }

    // --- Create modal -----------------------------------------------------
    private Task ShowCreateAsync(IEnumerable<WorkflowDefinitionRecord> _)
    {
        var model = new WorkflowCreateModel();
        var option = new EditDialogOption<WorkflowCreateModel>
        {
            Title = "Thêm định nghĩa quy trình",
            Model = model,
            Size = Size.Medium,
            ItemsPerRow = 1,
            ShowLoading = true,
            SaveButtonText = "Lưu",
            CloseButtonText = "Đóng",
            DialogBodyTemplate = CreateBody,
            OnEditAsync = async _ =>
            {
                try
                {
                    Guid? tenantId = Guid.TryParse(model.TenantId, out var parsed) ? parsed : null;
                    var steps = model.Steps.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                    await Api.CreateWorkflowDefinitionAsync(new CreateWorkflowDefinitionRequest(tenantId, model.Code, model.Name, steps));
                    await ToastService.Success("Thành công", "Đã tạo định nghĩa quy trình.");
                    await ReloadTableAsync();
                    return true;
                }
                catch (Exception ex)
                {
                    await ShowErrorAsync(ex);
                    return false;
                }
            }
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<WorkflowCreateModel> CreateBody => model =>
    @<div class="row g-3">
        <div class="col-12">
            <Select TValue="string" @bind-Value="model.TenantId" Items="_tenantOptions"
                    DisplayText="Mã khách thuê" ShowLabel="true" ShowSearch="true" PlaceHolder="Chọn khách thuê" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.Code" DisplayText="Mã" ShowLabel="true" />
        </div>
        <div class="col-md-6">
            <BootstrapInput @bind-Value="model.Name" DisplayText="Tên" ShowLabel="true" />
        </div>
        <div class="col-12">
            <BootstrapInput @bind-Value="model.Steps" DisplayText="Các bước" ShowLabel="true" PlaceHolder="Manager, Finance" />
        </div>
    </div>;

    private Task ShowEditAsync(IEnumerable<WorkflowDefinitionRecord> rows)
    {
        var definition = rows.FirstOrDefault();
        if (definition is null)
        {
            return Task.CompletedTask;
        }

        var model = new WorkflowViewModel
        {
            Code = definition.Code,
            Name = definition.Name,
            Steps = string.Join(" -> ", definition.Steps)
        };

        var option = new EditDialogOption<WorkflowViewModel>
        {
            Title = $"Quy trình: {definition.Code}",
            Model = model,
            Size = Size.Small,
            ItemsPerRow = 1,
            ShowLoading = false,
            SaveButtonText = "Đóng",
            CloseButtonText = "Huỷ",
            DialogBodyTemplate = ViewWorkflowBody,
            OnEditAsync = _ => Task.FromResult(true)
        };

        return DialogService.ShowEditDialog(option);
    }

    private RenderFragment<WorkflowViewModel> ViewWorkflowBody => model =>
    @<div class="row g-3">
        <div class="col-md-6">
            <BootstrapInput Value="@model.Code" DisplayText="Mã" ShowLabel="true" IsDisabled="true" />
        </div>
        <div class="col-md-6">
            <BootstrapInput Value="@model.Name" DisplayText="Tên" ShowLabel="true" IsDisabled="true" />
        </div>
        <div class="col-12">
            <BootstrapInput Value="@model.Steps" DisplayText="Các bước" ShowLabel="true" IsDisabled="true" />
        </div>
    </div>;

    // --- Start an approval instance for the selected definition ----------
    private async Task StartInstanceAsync(IEnumerable<WorkflowDefinitionRecord> rows)
    {
        var definition = rows.FirstOrDefault();
        if (definition is null)
        {
            return;
        }

        try
        {
            Guid? tenantId = definition.TenantId;
            var instance = await Api.CreateWorkflowInstanceAsync(
                new CreateWorkflowInstanceRequest(tenantId, definition.Id, "Accounting", "PaymentRequest", Guid.NewGuid().ToString()));
            await ToastService.Success("Đã khởi tạo phiên", $"Phiên {instance?.Id} – trạng thái {instance?.Status}.");
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    // --- Delete -----------------------------------------------------------
    private async Task DeleteSelectedAsync(IEnumerable<WorkflowDefinitionRecord> rows)
    {
        var list = rows?.ToList() ?? [];
        if (list.Count == 0)
        {
            await ToastService.Information("Chưa chọn", "Vui lòng chọn ít nhất một dòng để xoá.");
            return;
        }

        var confirmed = await SwalService.ShowModal(new SwalOption
        {
            Category = SwalCategory.Question,
            Title = "Xác nhận xoá",
            Content = list.Count == 1
                ? $"Bạn có chắc muốn xoá định nghĩa \"{list[0].Code}\"?"
                : $"Bạn có chắc muốn xoá {list.Count} định nghĩa đã chọn?"
        });
        if (!confirmed)
        {
            return;
        }

        try
        {
            foreach (var definition in list)
            {
                await Api.DeleteWorkflowDefinitionAsync(definition.Id);
            }

            await ToastService.Success("Đã xoá", "Đã xoá định nghĩa đã chọn.");
            await ReloadTableAsync();
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private Task ShowErrorAsync(Exception ex) => SwalService.Show(new SwalOption
    {
        Category = SwalCategory.Error,
        Title = "Đã xảy ra lỗi",
        Content = ex.Message
    });

    private sealed class WorkflowCreateModel
    {
        public string TenantId { get; set; } = "";

        [Required(ErrorMessage = "Vui lòng nhập mã")]
        public string Code { get; set; } = "PAYMENT_APPROVAL";

        [Required(ErrorMessage = "Vui lòng nhập tên")]
        public string Name { get; set; } = "Payment Approval";

        [Required(ErrorMessage = "Vui lòng nhập các bước")]
        public string Steps { get; set; } = "Manager, Finance";
    }

    private sealed class WorkflowViewModel
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Steps { get; set; } = "";
    }
}
