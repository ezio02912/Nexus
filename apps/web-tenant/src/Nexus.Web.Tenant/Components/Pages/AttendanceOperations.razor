    private static string BlankDefault(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    private static DateOnly ToDate(DateTime? value) => DateOnly.FromDateTime(value ?? DateTime.Today);
    private static TimeOnly ToTime(DateTime? value, int fallbackHour) => TimeOnly.FromDateTime(value ?? DateTime.Today.AddHours(fallbackHour));
    private static DateTimeOffset? ToDateTimeOffset(DateTime? value) => value.HasValue ? new DateTimeOffset(value.Value) : null;
    private static Guid? ParseGuid(string? value) => Guid.TryParse(value, out var id) ? id : null;
    private static int WorkedMinutes(DateTime? start, DateTime? end) => start.HasValue && end.HasValue && end.Value > start.Value ? (int)(end.Value - start.Value).TotalMinutes : 0;
    private static decimal ParseLeadingDecimal(string text) => decimal.TryParse(new string(text.TakeWhile(x => char.IsDigit(x) || x == '.' || x == ',').ToArray()).Replace(',', '.'), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var value) ? value : 0;
    private string EmployeeCode(Guid id) => _employees.FirstOrDefault(x => x.Id == id)?.EmployeeCode ?? id.ToString("N")[..8];
    private string EmployeeName(Guid id) => _employees.FirstOrDefault(x => x.Id == id)?.FullName ?? $"Employee {id.ToString("N")[..8]}";
    private string DepartmentName(Guid? id) => id.HasValue ? _departments.FirstOrDefault(x => x.Id == id.Value)?.Name ?? "-" : "-";
    private string ShiftName(Guid? id) => id.HasValue ? _shifts.FirstOrDefault(x => x.Id == id.Value)?.Name ?? "-" : "-";
    private string LeaveTypeName(Guid id) => _leaveTypes.FirstOrDefault(x => x.Id == id)?.Name ?? "-";
}
