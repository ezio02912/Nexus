@page "/crm/activities"
@attribute [TabItemOption(Text = "Hoạt động", Icon = "fa-solid fa-calendar-check")]
@inherits CrmPageBase

<PageTitle>Hoạt động - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Hoạt động</h1>
            <p>Quản lý cuộc gọi, họp, email và công việc CRM.</p>
        </div>
    </header>

    @if (!Can(NexusPermissions.Crm.Activities.View))
    {
        <div class="app-alert">@AccessDeniedMessage</div>
    }
    else if (!HasCrmModule)
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else
    {
        <Card HeaderText="Danh sách hoạt động" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="ActivityDto" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
                       ShowEditButton="false" ShowDeleteButton="false"
                       ShowExtendEditButton="false" ShowExtendDeleteButton="false"
                       ExtendButtonColumnWidth="180"
                       ShowSearch="false" ShowRefresh="true">
                    <TableToolbarTemplate>
                        @if (Can(NexusPermissions.Crm.Activities.Create))
                        {
                            <TableToolbarButton TItem="ActivityDto" Color="Color.Primary" Icon="fa-solid fa-plus"
                                            Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                        }
                    </TableToolbarTemplate>
                    <RowButtonTemplate>
                        @if (Can(NexusPermissions.Crm.Activities.Complete))
                        {
                            <TableCellButton Color="Color.Success" Icon="fa-solid fa-check" Text="Hoàn thành"
                                         IsDisabled="@(context.Status == CrmActivityStatus.Completed)"
                                         OnClick="@(() => CompleteAsync(context.Id))" />
                        }
                        @if (Can(NexusPermissions.Crm.Activities.Edit))
                        {
                            <TableCellButton Color="Color.Primary" Icon="fa-solid fa-pen" Text="Sửa"
                                         OnClick="@(() => ShowEditAsync(context))" />
                        }
                        @if (Can(NexusPermissions.Crm.Activities.Delete))
                        {
                            <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                         OnClick="@(() => DeleteAsync(context.Id))" />
                        }
                    </RowButtonTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.Subject" Text="Tiêu đề" Sortable="true" />
                        <TableColumn @bind-Field="@context.ActivityType" Text="Loại">
                            <Template Context="v">@CrmLabels.FormatActivityType(v.Row.ActivityType)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.RelatedEntityType" Text="Liên kết">
                            <Template Context="v">@CrmLabels.FormatRelatedEntityType(v.Row.RelatedEntityType)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.ActivityDate" Text="Thời gian" Sortable="true">
                            <Template Context="v">@v.Row.ActivityDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.DueDate" Text="Hạn">
                            <Template Context="v">@(v.Row.DueDate?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Status" Text="Trạng thái" Sortable="true">
                            <Template Context="v">@CrmLabels.FormatActivityStatus(v.Row.Status)</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="@_modalTitle" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Loại thực thể" Required="true">
                    <Select TValue="string" @bind-Value="_relatedTypeText" Items="@_relatedTypeOptions" ShowLabel="false" ShowSearch="true" />
                </AppFormField>
                <AppFormField Label="ID thực thể (GUID)" Required="true">
                    <BootstrapInput @bind-Value="_relatedEntityIdText" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Loại hoạt động">
                    <Select TValue="string" @bind-Value="_activityTypeText" Items="@_activityTypeOptions" ShowLabel="false" ShowSearch="true" />
                </AppFormField>
                <AppFormField Label="Tiêu đề" Required="true">
                    <BootstrapInput @bind-Value="_model.Subject" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Thời gian">
                    <DateTimePicker @bind-Value="_model.ActivityDate" ShowLabel="false" />
                </AppFormField>
                @if (!_isCreate)
                {
                    <AppFormField Label="Mô tả">
                        <BootstrapInput @bind-Value="_model.Description" ShowLabel="false" />
                    </AppFormField>
                    <AppStatusSelect Label="Trạng thái" @bind-Value="_statusText"
                                     Items="@_statusOptions" Meta="@_statusMeta" />
                }
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
