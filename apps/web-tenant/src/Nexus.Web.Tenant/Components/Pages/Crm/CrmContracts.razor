@page "/crm/contracts"
@attribute [TabItemOption(Text = "Hợp đồng", Icon = "fa-solid fa-file-signature")]
@inherits CrmPageBase

<PageTitle>Hợp đồng - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Hợp đồng</h1>
            <p>Quản lý hợp đồng khách hàng trong tenant hiện tại.</p>
        </div>
    </header>

    @if (!Can(NexusPermissions.Crm.Contracts.View))
    {
        <div class="app-alert">@AccessDeniedMessage</div>
    }
    else if (!HasCrmModule)
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else
    {
        <Card HeaderText="Danh sách hợp đồng" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="ContractDto" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
                       ShowEditButton="false" ShowDeleteButton="false"
                       ShowExtendEditButton="false" ShowExtendDeleteButton="false"
                       ExtendButtonColumnWidth="220"
                       ShowSearch="true" ShowSearchText="true" ShowRefresh="true" ShowAdvancedSearch="false">
                    <TableToolbarTemplate>
                        @if (Can(NexusPermissions.Crm.Contracts.Create))
                        {
                            <TableToolbarButton TItem="ContractDto" Color="Color.Primary" Icon="fa-solid fa-plus"
                                            Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                        }
                    </TableToolbarTemplate>
                    <RowButtonTemplate>
                        <TableCellButton Color="Color.Info" Icon="fa-solid fa-eye" Text="Chi tiết"
                                         OnClick="@(() => ViewDetailAsync(context.Id))" />
                        @if (Can(NexusPermissions.Crm.Contracts.Sign))
                        {
                            <TableCellButton Color="Color.Success" Icon="fa-solid fa-signature" Text="Ký"
                                         IsDisabled="@(context.Status >= ContractStatus.Signed)"
                                         OnClick="@(() => SignAsync(context.Id))" />
                        }
                        @if (Can(NexusPermissions.Crm.Contracts.Delete))
                        {
                            <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                         OnClick="@(() => DeleteAsync(context.Id))" />
                        }
                    </RowButtonTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.ContractNo" Text="Số HĐ" Sortable="true" Searchable="true" />
                        <TableColumn @bind-Field="@context.Title" Text="Tiêu đề" Searchable="true" />
                        <TableColumn @bind-Field="@context.CustomerId" Text="Khách hàng">
                            <Template Context="v">@CustomerName(v.Row.CustomerId)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.ContractValue" Text="Giá trị" Sortable="true">
                            <Template Context="v">@v.Row.ContractValue.ToString("N0") @v.Row.Currency</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Status" Text="Trạng thái" Sortable="true">
                            <Template Context="v">
                                <span class="@CrmLabels.StatusBadgeClass(v.Row.Status)">@CrmLabels.FormatContractStatus(v.Row.Status)</span>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.StartDate" Text="Bắt đầu">
                            <Template Context="v">@(v.Row.StartDate?.ToString("dd/MM/yyyy") ?? "—")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.EndDate" Text="Kết thúc">
                            <Template Context="v">@(v.Row.EndDate?.ToString("dd/MM/yyyy") ?? "—")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.SignedAt" Text="Ngày ký">
                            <Template Context="v">@(v.Row.SignedAt?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="Thêm hợp đồng" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <CustomerLookupSelect Label="Khách hàng" Required="true" @bind-Value="_customerIdText" />
                <AppFormField Label="Số hợp đồng" Required="true">
                    <BootstrapInput @bind-Value="_model.ContractNo" ShowLabel="false" PlaceHolder="AUTO để tự sinh số" />
                </AppFormField>
                <AppFormField Label="Tiêu đề" Required="true">
                    <BootstrapInput @bind-Value="_model.Title" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Giá trị" @bind-Value="_model.ContractValue" DecimalPlaces="0" />
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
