@page "/crm/dashboard"
@attribute [TabItemOption(Text = "CRM Dashboard", Icon = "fa-solid fa-gauge-high")]
@inherits CrmPageBase

<PageTitle>CRM Dashboard</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Bảng điều khiển CRM</h1>
            <p>Tổng quan pipeline, lead, báo giá và hợp đồng.</p>
        </div>
        <Button Text="Làm mới" Color="Color.Secondary" Icon="fa-solid fa-rotate" IsAsync="true" OnClick="LoadAsync" />
    </header>

    @if (!Can(NexusPermissions.Crm.Dashboard.View))
    {
        <div class="app-alert">@AccessDeniedMessage</div>
    }
    else if (!HasCrmModule)
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else if (_loading)
    {
        <div class="app-loading">
            <Spinner Color="Color.Primary" />
            <span class="app-loading-text">Đang tải dữ liệu...</span>
        </div>
    }
    else if (_dashboard is null)
    {
        <div class="app-empty-state">Không có dữ liệu dashboard.</div>
    }
    else
    {
        <div class="tenant-dashboard-grid">
            <div class="app-card tenant-kpi-card">
                <p class="tenant-kpi-label">Giá trị pipeline</p>
                <h2>@_dashboard.PipelineValue.ToString("N0")</h2>
            </div>
            <div class="app-card tenant-kpi-card">
                <p class="tenant-kpi-label">Lead mới</p>
                <h2>@_dashboard.NewLeadsCount</h2>
            </div>
            <div class="app-card tenant-kpi-card">
                <p class="tenant-kpi-label">Báo giá chờ xử lý</p>
                <h2>@_dashboard.PendingQuotationsCount</h2>
            </div>
            <div class="app-card tenant-kpi-card">
                <p class="tenant-kpi-label">Hợp đồng sắp hết hạn</p>
                <h2>@_dashboard.ExpiringContractsCount</h2>
            </div>
        </div>

        <Card HeaderText="Phễu cơ hội theo giai đoạn" IsShadow="true" class="mt-3">
            <BodyTemplate>
                @if (!_dashboard.StageFunnelItems.Any())
                {
                    <div class="app-empty-state">Chưa có dữ liệu phễu.</div>
                }
                else
                {
                    <Table TItem="CrmPipelineFunnelItemDto" Items="@_dashboard.StageFunnelItems.ToList()"
                           IsPagination="false" IsStriped="true" IsBordered="true">
                        <TableColumns>
                            <TableColumn @bind-Field="@context.Stage" Text="Giai đoạn">
                                <Template Context="v">@CrmLabels.FormatOpportunityStage(v.Row.Stage)</Template>
                            </TableColumn>
                            <TableColumn @bind-Field="@context.Count" Text="Số lượng" Sortable="true" />
                            <TableColumn @bind-Field="@context.TotalAmount" Text="Tổng giá trị">
                                <Template Context="v">@v.Row.TotalAmount.ToString("N0")</Template>
                            </TableColumn>
                        </TableColumns>
                    </Table>
                }
            </BodyTemplate>
        </Card>
    }
</section>
