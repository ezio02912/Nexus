@page "/crm/leads"
@attribute [TabItemOption(Text = "Leads", Icon = "fa-solid fa-user-plus")]
@inherits CrmPageBase

<PageTitle>Leads - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Leads</h1>
            <p>Quản lý lead tiềm năng trong tenant hiện tại.</p>
        </div>
    </header>

    @if (!Can(NexusPermissions.Crm.Leads.View))
    {
        <div class="app-alert">@AccessDeniedMessage</div>
    }
    else if (!HasCrmModule)
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else
    {
        <Card HeaderText="Danh sách leads" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="LeadDto" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
                       ShowEditButton="false" ShowDeleteButton="false"
                       ShowExtendEditButton="false" ShowExtendDeleteButton="false"
                       ExtendButtonColumnWidth="180"
                       ShowSearch="true" ShowSearchText="true" ShowRefresh="true" ShowAdvancedSearch="false">
                    <TableToolbarTemplate>
                        @if (Can(NexusPermissions.Crm.Leads.Create))
                        {
                            <TableToolbarButton TItem="LeadDto" Color="Color.Primary" Icon="fa-solid fa-plus"
                                            Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                        }
                    </TableToolbarTemplate>
                    <RowButtonTemplate>
                        <TableCellButton Color="Color.Info" Icon="fa-solid fa-eye" Text="Chi tiết"
                                         OnClick="@(() => ViewDetailAsync(context.Id))" />
                        @if (Can(NexusPermissions.Crm.Leads.Edit))
                        {
                            <TableCellButton Color="Color.Primary" Icon="fa-solid fa-pen" Text="Sửa"
                                         OnClick="@(() => ShowEditAsync(context))" />
                        }
                        @if (Can(NexusPermissions.Crm.Leads.Delete))
                        {
                            <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                         OnClick="@(() => DeleteAsync(context.Id))" />
                        }
                    </RowButtonTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.FullName" Text="Họ tên" Sortable="true" Searchable="true">
                            <Template Context="v">
                                <button class="app-table-link" type="button" @onclick="@(() => ViewDetailAsync(v.Row.Id))">
                                    @v.Row.FullName
                                </button>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.CompanyName" Text="Công ty" Searchable="true" />
                        <TableColumn @bind-Field="@context.Title" Text="Chức danh" />
                        <TableColumn @bind-Field="@context.Email" Text="Email" />
                        <TableColumn @bind-Field="@context.Phone" Text="Điện thoại" />
                        <TableColumn @bind-Field="@context.Source" Text="Nguồn" />
                        <TableColumn @bind-Field="@context.LeadScore" Text="Điểm" Sortable="true" />
                        <TableColumn @bind-Field="@context.Rating" Text="Xếp hạng">
                            <Template Context="v">@(v.Row.Rating.HasValue ? CrmLabels.FormatLeadRating(v.Row.Rating.Value) : "—")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.City" Text="Thành phố" />
                        <TableColumn @bind-Field="@context.ConvertedCustomerId" Text="KH chuyển đổi">
                            <Template Context="v">
                                @if (v.Row.ConvertedCustomerId.HasValue)
                                {
                                    <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => ViewCustomerDetail(v.Row.ConvertedCustomerId.Value))">
                                        Mở khách hàng
                                    </button>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Status" Text="Trạng thái" Sortable="true">
                            <Template Context="v">
                                <span class="@CrmLabels.StatusBadgeClass(v.Row.Status)">@CrmLabels.FormatLeadStatus(v.Row.Status)</span>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.CreationTime" Text="Ngày tạo" Sortable="true">
                            <Template Context="v">@v.Row.CreationTime.ToLocalTime().ToString("dd/MM/yyyy")</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="@_modalTitle" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Họ tên" Required="true">
                    <BootstrapInput @bind-Value="_model.FullName" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Công ty">
                    <BootstrapInput @bind-Value="_model.CompanyName" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Chức danh">
                    <BootstrapInput @bind-Value="_model.Title" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Email">
                    <BootstrapInput @bind-Value="_model.Email" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Điện thoại">
                    <BootstrapInput @bind-Value="_model.Phone" ShowLabel="false" />
                </AppFormField>
                <MasterDataLookupSelect Category="@MasterDataCategories.Source" Label="Nguồn"
                                        @bind-Value="_model.Source" PlaceHolder="Chọn nguồn..." />
                @if (!_isCreate)
                {
                    <AppFormField Label="Điểm lead">
                        <BootstrapInputNumber @bind-Value="_model.LeadScore" ShowLabel="false" />
                    </AppFormField>
                    <AppStatusSelect Label="Trạng thái" @bind-Value="_statusText"
                                     Items="@_statusOptions" Meta="@_statusMeta" />
                }
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
