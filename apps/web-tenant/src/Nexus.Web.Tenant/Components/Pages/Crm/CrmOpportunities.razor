@page "/crm/opportunities"
@attribute [TabItemOption(Text = "Cơ hội", Icon = "fa-solid fa-bullseye")]
@inherits CrmPageBase

<PageTitle>Cơ hội - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Cơ hội</h1>
            <p>Quản lý cơ hội bán hàng trong tenant hiện tại.</p>
        </div>
        <Button Text="Kanban" Color="Color.Info" Icon="fa-solid fa-table-columns" OnClick="GoToBoard" />
    </header>

    @if (!Can(NexusPermissions.Crm.Opportunities.View))
    {
        <div class="app-alert">@AccessDeniedMessage</div>
    }
    else if (!HasCrmModule)
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else
    {
        <Card HeaderText="Danh sách cơ hội" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="OpportunityDto" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
                       ShowEditButton="false" ShowDeleteButton="false"
                       ShowExtendEditButton="false" ShowExtendDeleteButton="false"
                       ExtendButtonColumnWidth="180"
                       ShowSearch="true" ShowSearchText="true" ShowRefresh="true" ShowAdvancedSearch="false">
                    <TableToolbarTemplate>
                        @if (Can(NexusPermissions.Crm.Opportunities.Create))
                        {
                            <TableToolbarButton TItem="OpportunityDto" Color="Color.Primary" Icon="fa-solid fa-plus"
                                            Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                        }
                    </TableToolbarTemplate>
                    <RowButtonTemplate>
                        <TableCellButton Color="Color.Info" Icon="fa-solid fa-eye" Text="Chi tiết"
                                         OnClick="@(() => ViewDetailAsync(context.Id))" />
                        @if (Can(NexusPermissions.Crm.Opportunities.Edit))
                        {
                            <TableCellButton Color="Color.Primary" Icon="fa-solid fa-pen" Text="Sửa"
                                         OnClick="@(() => ShowEditAsync(context))" />
                        }
                        @if (Can(NexusPermissions.Crm.Opportunities.Delete))
                        {
                            <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                         OnClick="@(() => DeleteAsync(context.Id))" />
                        }
                    </RowButtonTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.Name" Text="Tên" Sortable="true" Searchable="true" />
                        <TableColumn @bind-Field="@context.CustomerId" Text="Khách hàng">
                            <Template Context="v">@CustomerName(v.Row.CustomerId)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Stage" Text="Giai đoạn" Sortable="true">
                            <Template Context="v">
                                <span class="@CrmLabels.StatusBadgeClass(v.Row.Stage)">@CrmLabels.FormatOpportunityStage(v.Row.Stage)</span>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Amount" Text="Giá trị" Sortable="true">
                            <Template Context="v">@VnMoney.Format(v.Row.Amount) @v.Row.Currency</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Probability" Text="Xác suất (%)" Sortable="true" />
                        <TableColumn @bind-Field="@context.ExpectedCloseDate" Text="Dự kiến chốt">
                            <Template Context="v">@(v.Row.ExpectedCloseDate?.ToString("dd/MM/yyyy") ?? "—")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.NextStep" Text="Bước tiếp theo" />
                        <TableColumn @bind-Field="@context.CreationTime" Text="Ngày tạo" Sortable="true">
                            <Template Context="v">@v.Row.CreationTime.ToLocalTime().ToString("dd/MM/yyyy")</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="@_modalTitle" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <CustomerLookupSelect Label="Khách hàng" @bind-Value="_customerIdText" />
                <AppFormField Label="Tên cơ hội" Required="true">
                    <BootstrapInput @bind-Value="_model.Name" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Giá trị" @bind-Value="_model.Amount" DecimalPlaces="0" />
                @if (!_isCreate)
                {
                    <AppFormField Label="Xác suất (%)">
                        <BootstrapInputNumber @bind-Value="_model.Probability" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Tiền tệ">
                        <BootstrapInput @bind-Value="_model.Currency" ShowLabel="false" />
                    </AppFormField>
                    <AppStatusSelect Label="Giai đoạn" @bind-Value="_stageText"
                                     Items="@_stageOptions" Meta="@_stageMeta" />
                }
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
