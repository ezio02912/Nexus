@page "/crm/opportunities"
@attribute [TabItemOption(Text = "Cơ hội", Icon = "fa-solid fa-bullseye")]
@inject TenantPortalApiClient Api
@inject TenantSessionService Session

<PageTitle>Cơ hội - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Cơ hội</h1>
            <p>Quản lý cơ hội bán hàng trong tenant hiện tại.</p>
        </div>
        <Button Text="Tải lại" Color="Color.Secondary" OnClick="LoadAsync" />
    </header>

    @if (!Session.HasModule("CRM"))
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="@messageCss">@message</div>
        }

        <div class="tenant-work-grid">
            <section class="app-card">
                <h2>Tạo cơ hội</h2>
                <div class="app-form-grid">
                    <div>
                        <label>Khách hàng</label>
                        <select class="form-select" @bind="opportunityCustomerId">
                            <option value="">Chưa chọn khách hàng</option>
                            @foreach (var customer in customers)
                            {
                                <option value="@customer.Id">@CustomerOption(customer)</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label>Tên cơ hội *</label>
                        <input class="form-control" @bind="opportunityName" />
                    </div>
                    <div>
                        <label>Giá trị</label>
                        <input class="form-control" type="number" @bind="opportunityAmount" />
                    </div>
                </div>
                <Button Text="Tạo cơ hội" Color="Color.Primary" OnClick="CreateOpportunityAsync" />
            </section>

            <section class="app-card app-card-wide">
                <h2>Danh sách cơ hội</h2>
                @if (isLoading)
                {
                    <div class="app-loading">Đang tải cơ hội...</div>
                }
                else if (opportunities.Count == 0)
                {
                    <div class="app-empty-state">Chưa có cơ hội.</div>
                }
                else
                {
                    <table class="app-table">
                        <thead><tr><th>Tên</th><th>Giai đoạn</th><th>Giá trị</th><th>Dự kiến chốt</th></tr></thead>
                        <tbody>
                            @foreach (var item in opportunities)
                            {
                                <tr><td>@item.Name</td><td>@item.Stage</td><td>@item.Amount.ToString("N2")</td><td>@item.ExpectedCloseDate</td></tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        </div>
    }
</section>

@code {
    private List<CustomerRecord> customers = [];
    private List<OpportunityRecord> opportunities = [];
    private bool isLoading;
    private string message = "";
    private string messageCss = "app-alert";

    private string opportunityCustomerId = "";
    private string opportunityName = "";
    private decimal opportunityAmount = 1000;

    private static string CustomerOption(CustomerRecord customer) => $"{customer.Code} - {customer.Name}";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (Session.TenantId is not Guid tenantId)
        {
            return;
        }

        isLoading = true;
        customers = (await Api.GetCustomersAsync(tenantId))?.Items.ToList() ?? [];
        opportunities = (await Api.GetOpportunitiesAsync(tenantId))?.ToList() ?? [];
        isLoading = false;
    }

    private async Task CreateOpportunityAsync()
    {
        if (Session.TenantId is not Guid tenantId || string.IsNullOrWhiteSpace(opportunityName))
        {
            ShowError("Vui lòng nhập tên cơ hội.");
            return;
        }

        Guid? customerId = Guid.TryParse(opportunityCustomerId, out var parsedCustomerId) ? parsedCustomerId : null;
        await Api.CreateOpportunityAsync(new CreateOpportunityRequest(tenantId, customerId, opportunityName, opportunityAmount, null));
        opportunityName = "";
        ShowSuccess("Đã tạo cơ hội.");
        await LoadAsync();
    }

    private void ShowSuccess(string text)
    {
        message = text;
        messageCss = "app-alert";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCss = "app-alert app-alert-danger";
    }
}
