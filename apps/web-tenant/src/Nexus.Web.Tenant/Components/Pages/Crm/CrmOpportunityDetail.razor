@page "/crm/opportunities/{Id:guid}"
@attribute [TabItemOption(Text = "Chi tiết cơ hội", Icon = "fa-solid fa-bullseye")]
@inherits CrmPageBase

<PageTitle>Chi tiết cơ hội - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM / Cơ hội</p>
            <h1>@(_item?.Name ?? "Chi tiết cơ hội")</h1>
        </div>
        <div class="d-flex gap-2">
            <Button Text="Quay lại" Color="Color.Secondary" Icon="fa-solid fa-arrow-left" OnClick="GoBack" />
            @if (_item?.CustomerId is not null)
            {
                <Button Text="Tạo báo giá" Color="Color.Primary" Icon="fa-solid fa-file-invoice" IsAsync="true" OnClick="ShowCreateQuotationAsync" />
            }
            @if (_item is not null)
            {
                <Button Text="Sửa" Color="Color.Primary" Icon="fa-solid fa-pen" IsAsync="true" OnClick="ShowEditModalAsync" />
            }
            <Button Text="Làm mới" Color="Color.Secondary" Icon="fa-solid fa-rotate" IsAsync="true" OnClick="LoadAsync" />
        </div>
    </header>

    @if (_loading)
    {
        <div class="app-loading">
            <Spinner Color="Color.Primary" />
            <span class="app-loading-text">Đang tải dữ liệu...</span>
        </div>
    }
    else if (_item is null)
    {
        <div class="app-empty-state">Không tìm thấy cơ hội.</div>
    }
    else
    {
        <section class="app-card app-card-wide">
            <div class="app-detail-grid">
                <div><span class="app-detail-label">Giai đoạn</span><span>@CrmLabels.FormatOpportunityStage(_item.Stage)</span></div>
                <div><span class="app-detail-label">Giá trị</span><span>@_item.Amount.ToString("N0") @_item.Currency</span></div>
                <div><span class="app-detail-label">Xác suất</span><span>@_item.Probability%</span></div>
                <div><span class="app-detail-label">Dự kiến chốt</span><span>@(_item.ExpectedCloseDate?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                <div><span class="app-detail-label">Ngày chốt thực tế</span><span>@(_item.ActualCloseDate?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                <div><span class="app-detail-label">Bước tiếp theo</span><span>@(_item.NextStep ?? "—")</span></div>
                <div><span class="app-detail-label">Ngày bước tiếp</span><span>@(_item.NextStepDate?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                <div><span class="app-detail-label">Nguồn</span><span>@(_item.Source ?? "—")</span></div>
                <div><span class="app-detail-label">Đối thủ</span><span>@(_item.Competitor ?? "—")</span></div>
                <div><span class="app-detail-label">Ngày tạo</span><span>@_item.CreationTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></div>
            </div>
            @if (!string.IsNullOrWhiteSpace(_item.Description))
            {
                <p class="mt-3 text-muted">@_item.Description</p>
            }
        </section>

        <div class="crm-related-grid mt-3">
            @if (_customer is not null)
            {
                <button class="app-card crm-related-summary" type="button" @onclick="@(() => OpenCustomer(_customer.Id))">
                    <span class="app-detail-label">Khách hàng</span>
                    <strong>@_customer.Code - @_customer.Name</strong>
                    <span>@(_customer.Email ?? _customer.Phone ?? "Mở chi tiết khách hàng")</span>
                </button>
            }
            @if (_lead is not null)
            {
                <button class="app-card crm-related-summary" type="button" @onclick="@(() => OpenLead(_lead.Id))">
                    <span class="app-detail-label">Lead nguồn</span>
                    <strong>@_lead.FullName</strong>
                    <span>@(_lead.CompanyName ?? _lead.Email ?? "Mở chi tiết lead")</span>
                </button>
            }
        </div>

        <div class="crm-related-grid mt-3">
            <section class="app-card">
                <h3>Báo giá</h3>
                @if (!_quotations.Any())
                {
                    <div class="app-empty-state">Chưa có báo giá cho cơ hội này.</div>
                }
                else
                {
                    @foreach (var item in _quotations.Take(6))
                    {
                        <button class="crm-related-row crm-related-button" type="button" @onclick="@(() => OpenQuotation(item.Id))">
                            <div>
                                <strong>@item.QuotationNo</strong>
                                <span>@VnMoney.Format(item.TotalAmount) @item.Currency</span>
                            </div>
                            <span class="@CrmLabels.StatusBadgeClass(item.Status)">@CrmLabels.FormatQuotationStatus(item.Status)</span>
                        </button>
                    }
                }
            </section>

            <section class="app-card">
                <h3>Hợp đồng</h3>
                @if (!_contracts.Any())
                {
                    <div class="app-empty-state">Chưa có hợp đồng cho cơ hội này.</div>
                }
                else
                {
                    @foreach (var item in _contracts.Take(6))
                    {
                        <button class="crm-related-row crm-related-button" type="button" @onclick="@(() => OpenContract(item.Id))">
                            <div>
                                <strong>@item.ContractNo</strong>
                                <span>@VnMoney.Format(item.ContractValue) @item.Currency</span>
                            </div>
                            <span class="@CrmLabels.StatusBadgeClass(item.Status)">@CrmLabels.FormatContractStatus(item.Status)</span>
                        </button>
                    }
                }
            </section>

            <section class="app-card app-card-wide">
                <h3>Hoạt động</h3>
                @if (!_activities.Any())
                {
                    <div class="app-empty-state">Chưa có hoạt động.</div>
                }
                else
                {
                    @foreach (var item in _activities.Take(8))
                    {
                        <div class="crm-related-row">
                            <div>
                                <strong>@item.Subject</strong>
                                <span>@CrmLabels.FormatActivityType(item.ActivityType) / @item.ActivityDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <span class="app-status-badge app-status-muted">@CrmLabels.FormatActivityStatus(item.Status)</span>
                        </div>
                    }
                }
            </section>
        </div>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="Sửa cơ hội" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <CustomerLookupSelect Label="Khách hàng" @bind-Value="_editCustomerIdText" />
                <AppFormField Label="Tên cơ hội" Required="true">
                    <BootstrapInput @bind-Value="_editModel.Name" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Giá trị" @bind-Value="_editModel.Amount" DecimalPlaces="0" />
                <AppFormField Label="Xác suất (%)">
                    <BootstrapInputNumber @bind-Value="_editModel.Probability" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Tiền tệ">
                    <BootstrapInput @bind-Value="_editModel.Currency" ShowLabel="false" />
                </AppFormField>
                <AppStatusSelect Label="Giai đoạn" @bind-Value="_editStageText"
                                 Items="@_stageOptions" Meta="@_stageMeta" />
                <AppFormField Label="Bước tiếp theo">
                    <BootstrapInput @bind-Value="_editModel.NextStep" ShowLabel="false" />
                </AppFormField>
                <MasterDataLookupSelect Category="@MasterDataCategories.Source" Label="Nguồn" @bind-Value="_editModel.Source" />
                <AppFormField Label="Đối thủ">
                    <BootstrapInput @bind-Value="_editModel.Competitor" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Mô tả">
                    <Textarea @bind-Value="_editModel.Description" ShowLabel="false" rows="3" />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseEditModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveEditAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_quotationModal" IsBackdrop="true">
    <ModalDialog Title="Tạo báo giá từ cơ hội" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tiêu đề">
                    <BootstrapInput @bind-Value="_quotationModel.Subject" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Mã hàng" Required="true">
                    <BootstrapInput @bind-Value="_quotationModel.ProductCode" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Tên hàng" Required="true">
                    <BootstrapInput @bind-Value="_quotationModel.ProductName" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Số lượng">
                    <BootstrapInputNumber @bind-Value="_quotationModel.Quantity" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Đơn giá" @bind-Value="_quotationModel.UnitPrice" DecimalPlaces="0" />
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseQuotationModalAsync" />
            <Button Text="Tạo báo giá" Color="Color.Primary" IsAsync="true" OnClick="CreateQuotationAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
