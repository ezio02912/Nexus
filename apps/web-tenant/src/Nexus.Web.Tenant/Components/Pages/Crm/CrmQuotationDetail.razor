@page "/crm/quotations/{Id:guid}"
@attribute [TabItemOption(Text = "Chi tiết báo giá", Icon = "fa-solid fa-file-invoice")]
@inherits CrmPageBase

<PageTitle>Chi tiết báo giá - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM / Báo giá</p>
            <h1>@(_item?.QuotationNo ?? "Chi tiết báo giá")</h1>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <Button Text="Quay lại" Color="Color.Secondary" Icon="fa-solid fa-arrow-left" OnClick="GoBack" />
            @if (_item is not null)
            {
                <Button Text="Gửi" Color="Color.Info" Icon="fa-solid fa-paper-plane" IsAsync="true" OnClick="SendAsync" />
                <Button Text="Duyệt" Color="Color.Success" Icon="fa-solid fa-check" IsAsync="true" OnClick="ApproveAsync" />
                <Button Text="Từ chối" Color="Color.Warning" Icon="fa-solid fa-ban" IsAsync="true" OnClick="RejectAsync" />
            }
            <Button Text="Làm mới" Color="Color.Secondary" Icon="fa-solid fa-rotate" IsAsync="true" OnClick="LoadAsync" />
        </div>
    </header>

    @if (_loading)
    {
        <div class="app-loading">
            <Spinner Color="Color.Primary" />
            <span class="app-loading-text">Đang tải dữ liệu...</span>
        </div>
    }
    else if (_item is null)
    {
        <div class="app-empty-state">Không tìm thấy báo giá.</div>
    }
    else
    {
        <section class="app-card app-card-wide mb-3">
            <div class="app-detail-grid">
                <div><span class="app-detail-label">Tiêu đề</span><span>@(_item.Subject ?? "—")</span></div>
                <div><span class="app-detail-label">Trạng thái</span>
                    <span class="@CrmLabels.StatusBadgeClass(_item.Status)">@CrmLabels.FormatQuotationStatus(_item.Status)</span>
                </div>
                <div><span class="app-detail-label">Tổng tiền</span><span>@_item.TotalAmount.ToString("N0") @_item.Currency</span></div>
                <div><span class="app-detail-label">Hiệu lực đến</span><span>@(_item.ValidUntil?.ToString("dd/MM/yyyy") ?? "—")</span></div>
            </div>
        </section>

        <Card HeaderText="Chi tiết dòng hàng" IsShadow="true">
            <BodyTemplate>
                @if (!_item.Lines.Any())
                {
                    <div class="app-empty-state">Chưa có dòng hàng.</div>
                }
                else
                {
                    <Table TItem="QuotationLineDto" Items="@_item.Lines.ToList()" IsPagination="false" IsStriped="true" IsBordered="true">
                        <TableColumns>
                            <TableColumn @bind-Field="@context.LineNo" Text="#" />
                            <TableColumn @bind-Field="@context.ProductCode" Text="Mã SP" />
                            <TableColumn @bind-Field="@context.ProductName" Text="Tên SP" />
                            <TableColumn @bind-Field="@context.Quantity" Text="SL" />
                            <TableColumn @bind-Field="@context.UnitPrice" Text="Đơn giá">
                                <Template Context="v">@v.Row.UnitPrice.ToString("N0")</Template>
                            </TableColumn>
                            <TableColumn @bind-Field="@context.LineTotal" Text="Thành tiền">
                                <Template Context="v">@v.Row.LineTotal.ToString("N0")</Template>
                            </TableColumn>
                        </TableColumns>
                    </Table>
                }
            </BodyTemplate>
        </Card>
    }
</section>
