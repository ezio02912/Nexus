@page "/crm/customers/{Id:guid}"
@attribute [TabItemOption(Text = "Chi tiết KH", Icon = "fa-solid fa-building-user")]
@inherits CrmPageBase

<PageTitle>Chi tiết khách hàng - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM / Khách hàng</p>
            <h1>@(_customer?.Name ?? "Chi tiết khách hàng")</h1>
        </div>
        <div class="d-flex gap-2">
            <Button Text="Quay lại" Color="Color.Secondary" Icon="fa-solid fa-arrow-left" OnClick="GoBack" />
            @if (_customer is not null)
            {
                <Button Text="Sửa" Color="Color.Primary" Icon="fa-solid fa-pen" IsAsync="true" OnClick="ShowEditModalAsync" />
            }
            <Button Text="Làm mới" Color="Color.Secondary" Icon="fa-solid fa-rotate" IsAsync="true" OnClick="LoadAsync" />
        </div>
    </header>

    @if (_loading)
    {
        <div class="app-loading">
            <Spinner Color="Color.Primary" />
            <span class="app-loading-text">Đang tải dữ liệu...</span>
        </div>
    }
    else if (_customer is null)
    {
        <div class="app-empty-state">Không tìm thấy khách hàng.</div>
    }
    else
    {
        <section class="app-card app-card-wide customer-profile-panel">
            <header class="customer-profile-header">
                <div>
                    <h2>Thông tin chung</h2>
                    <p>@_customer.Code / @CrmLabels.FormatCustomerType(_customer.CustomerType)</p>
                </div>
                <span class="@CrmLabels.StatusBadgeClass(_customer.Status)">@CrmLabels.FormatCustomerStatus(_customer.Status)</span>
            </header>

            <div class="customer-info-grid">
                <div class="customer-info-item customer-info-highlight">
                    <span class="customer-info-icon"><i class="fa-solid fa-barcode"></i></span>
                    <div>
                        <span class="customer-info-label">Mã khách hàng</span>
                        <strong class="customer-info-value">@_customer.Code</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-building"></i></span>
                    <div>
                        <span class="customer-info-label">Loại</span>
                        <strong class="customer-info-value">@CrmLabels.FormatCustomerType(_customer.CustomerType)</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-envelope"></i></span>
                    <div>
                        <span class="customer-info-label">Email</span>
                        <strong class="customer-info-value">@(_customer.Email ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-phone"></i></span>
                    <div>
                        <span class="customer-info-label">Điện thoại</span>
                        <strong class="customer-info-value">@(_customer.Phone ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-briefcase"></i></span>
                    <div>
                        <span class="customer-info-label">Ngành</span>
                        <strong class="customer-info-value">@(_customer.Industry ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-location-dot"></i></span>
                    <div>
                        <span class="customer-info-label">Thành phố</span>
                        <strong class="customer-info-value">@(_customer.City ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-globe"></i></span>
                    <div>
                        <span class="customer-info-label">Website</span>
                        <strong class="customer-info-value">@(_customer.Website ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-receipt"></i></span>
                    <div>
                        <span class="customer-info-label">Mã số thuế</span>
                        <strong class="customer-info-value">@(_customer.TaxCode ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-bullhorn"></i></span>
                    <div>
                        <span class="customer-info-label">Nguồn</span>
                        <strong class="customer-info-value">@(_customer.Source ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-star"></i></span>
                    <div>
                        <span class="customer-info-label">Xếp hạng</span>
                        <strong class="customer-info-value">@(_customer.Rating.HasValue ? CrmLabels.FormatLeadRating(_customer.Rating.Value) : "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item customer-info-wide">
                    <span class="customer-info-icon"><i class="fa-solid fa-map-location-dot"></i></span>
                    <div>
                        <span class="customer-info-label">Địa chỉ</span>
                        <strong class="customer-info-value">@(_customer.AddressLine1 ?? "—")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-calendar-plus"></i></span>
                    <div>
                        <span class="customer-info-label">Ngày tạo</span>
                        <strong class="customer-info-value">@_customer.CreationTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                </div>
                <div class="customer-info-item">
                    <span class="customer-info-icon"><i class="fa-solid fa-clock-rotate-left"></i></span>
                    <div>
                        <span class="customer-info-label">Cập nhật</span>
                        <strong class="customer-info-value">@(_customer.LastModificationTime?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</strong>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_customer.Description))
            {
                <div class="customer-description">
                    <span class="customer-info-icon"><i class="fa-solid fa-align-left"></i></span>
                    <div>
                        <span class="customer-info-label">Mô tả</span>
                        <p>@_customer.Description</p>
                    </div>
                </div>
            }
        </section>

        <div class="crm-related-grid">
            <section class="app-card">
                <header class="crm-card-header">
                    <h3>Liên hệ</h3>
                    <button class="crm-card-add" type="button" title="Thêm liên hệ" @onclick="ShowCreateContactAsync">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </header>
                @if (!_contacts.Any())
                {
                    <div class="app-empty-state">Chưa có liên hệ.</div>
                }
                else
                {
                    @foreach (var contact in _contacts.Take(6))
                    {
                        <div class="crm-related-row">
                            <div>
                                <strong>@contact.FullName</strong>
                                <span>@(contact.Position ?? contact.Email ?? "—")</span>
                            </div>
                            <span class="app-status-badge app-status-muted">@(contact.IsPrimary ? "Chính" : "Liên hệ")</span>
                        </div>
                    }
                }
            </section>

            <section class="app-card">
                <header class="crm-card-header">
                    <h3>Cơ hội</h3>
                    <button class="crm-card-add" type="button" title="Thêm cơ hội" @onclick="ShowCreateOpportunityAsync">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </header>
                @if (!_opportunities.Any())
                {
                    <div class="app-empty-state">Chưa có cơ hội.</div>
                }
                else
                {
                    @foreach (var item in _opportunities.Take(6))
                    {
                        <button class="crm-related-row crm-related-button" type="button" @onclick="@(() => OpenOpportunity(item.Id))">
                            <div>
                                <strong>@item.Name</strong>
                                <span>@VnMoney.Format(item.Amount) @item.Currency</span>
                            </div>
                            <span class="@CrmLabels.StatusBadgeClass(item.Stage)">@CrmLabels.FormatOpportunityStage(item.Stage)</span>
                        </button>
                    }
                }
            </section>

            <section class="app-card">
                <header class="crm-card-header">
                    <h3>Báo giá</h3>
                    <button class="crm-card-add" type="button" title="Thêm báo giá" @onclick="ShowCreateQuotationAsync">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </header>
                @if (!_quotations.Any())
                {
                    <div class="app-empty-state">Chưa có báo giá.</div>
                }
                else
                {
                    @foreach (var item in _quotations.Take(6))
                    {
                        <button class="crm-related-row crm-related-button" type="button" @onclick="@(() => OpenQuotation(item.Id))">
                            <div>
                                <strong>@item.QuotationNo</strong>
                                <span>@VnMoney.Format(item.TotalAmount) @item.Currency</span>
                            </div>
                            <span class="@CrmLabels.StatusBadgeClass(item.Status)">@CrmLabels.FormatQuotationStatus(item.Status)</span>
                        </button>
                    }
                }
            </section>

            <section class="app-card">
                <header class="crm-card-header">
                    <h3>Hợp đồng</h3>
                    <button class="crm-card-add" type="button" title="Thêm hợp đồng" @onclick="ShowCreateContractAsync">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </header>
                @if (!_contracts.Any())
                {
                    <div class="app-empty-state">Chưa có hợp đồng.</div>
                }
                else
                {
                    @foreach (var item in _contracts.Take(6))
                    {
                        <button class="crm-related-row crm-related-button" type="button" @onclick="@(() => OpenContract(item.Id))">
                            <div>
                                <strong>@item.ContractNo</strong>
                                <span>@VnMoney.Format(item.ContractValue) @item.Currency</span>
                            </div>
                            <span class="@CrmLabels.StatusBadgeClass(item.Status)">@CrmLabels.FormatContractStatus(item.Status)</span>
                        </button>
                    }
                }
            </section>

            <section class="app-card app-card-wide">
                <header class="crm-card-header">
                    <h3>Hoạt động gần đây</h3>
                    <button class="crm-card-add" type="button" title="Thêm hoạt động" @onclick="ShowCreateActivityAsync">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                </header>
                @if (!_activities.Any())
                {
                    <div class="app-empty-state">Chưa có hoạt động.</div>
                }
                else
                {
                    @foreach (var item in _activities.Take(8))
                    {
                        <div class="crm-related-row">
                            <div>
                                <strong>@item.Subject</strong>
                                <span>@CrmLabels.FormatActivityType(item.ActivityType) / @item.ActivityDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <span class="app-status-badge app-status-muted">@CrmLabels.FormatActivityStatus(item.Status)</span>
                        </div>
                    }
                }
            </section>
        </div>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="Sửa khách hàng" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tên khách hàng" Required="true">
                    <BootstrapInput @bind-Value="_editModel.Name" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Loại">
                    <Select TValue="string" Items="@_customerTypeOptions" @bind-Value="_customerTypeText" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Email">
                    <BootstrapInput @bind-Value="_editModel.Email" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Điện thoại">
                    <BootstrapInput @bind-Value="_editModel.Phone" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Mã số thuế">
                    <BootstrapInput @bind-Value="_editModel.TaxCode" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Website">
                    <BootstrapInput @bind-Value="_editModel.Website" ShowLabel="false" />
                </AppFormField>
                <MasterDataLookupSelect Category="@MasterDataCategories.Industry" Label="Ngành" @bind-Value="_editModel.Industry" />
                <MasterDataLookupSelect Category="@MasterDataCategories.City" Label="Thành phố" @bind-Value="_editModel.City" />
                <MasterDataLookupSelect Category="@MasterDataCategories.Source" Label="Nguồn" @bind-Value="_editModel.Source" />
                <AppFormField Label="Địa chỉ">
                    <BootstrapInput @bind-Value="_editModel.AddressLine1" ShowLabel="false" />
                </AppFormField>
                <AppStatusSelect Label="Trạng thái" @bind-Value="_customerStatusText"
                                 Items="@_customerStatusOptions" Meta="@_customerStatusMeta" />
                <AppFormField Label="Mô tả">
                    <Textarea @bind-Value="_editModel.Description" ShowLabel="false" rows="3" />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseEditModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveEditAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_contactModal" IsBackdrop="true">
    <ModalDialog Title="Thêm liên hệ" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Họ tên" Required="true">
                    <BootstrapInput @bind-Value="_contactModel.FullName" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Email">
                    <BootstrapInput @bind-Value="_contactModel.Email" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Điện thoại">
                    <BootstrapInput @bind-Value="_contactModel.Phone" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Di động">
                    <BootstrapInput @bind-Value="_contactModel.Mobile" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Chức vụ">
                    <BootstrapInput @bind-Value="_contactModel.Position" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Phòng ban">
                    <BootstrapInput @bind-Value="_contactModel.Department" ShowLabel="false" />
                </AppFormField>
                <Checkbox @bind-Value="_contactModel.IsPrimary" ShowAfterLabel="true" DisplayText="Liên hệ chính" />
                <Checkbox @bind-Value="_contactModel.IsDecisionMaker" ShowAfterLabel="true" DisplayText="Người ra quyết định" />
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseContactModalAsync" />
            <Button Text="Tạo liên hệ" Color="Color.Primary" IsAsync="true" OnClick="CreateContactAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_opportunityModal" IsBackdrop="true">
    <ModalDialog Title="Thêm cơ hội" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tên cơ hội" Required="true">
                    <BootstrapInput @bind-Value="_opportunityModel.Name" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Giá trị" @bind-Value="_opportunityModel.Amount" DecimalPlaces="0" />
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseOpportunityModalAsync" />
            <Button Text="Tạo cơ hội" Color="Color.Primary" IsAsync="true" OnClick="CreateOpportunityAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_quotationModal" IsBackdrop="true">
    <ModalDialog Title="Thêm báo giá" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tiêu đề">
                    <BootstrapInput @bind-Value="_quotationModel.Subject" ShowLabel="false" />
                </AppFormField>
                <ProductLinesEditor Label="Dòng sản phẩm" @bind-Lines="_quotationModel.Lines" />
                <PendingFileAttachmentInput Label="Tệp báo giá" @bind-Files="_quotationModel.PendingFiles" />
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseQuotationModalAsync" />
            <Button Text="Tạo báo giá" Color="Color.Primary" IsAsync="true" OnClick="CreateQuotationAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_contractModal" IsBackdrop="true">
    <ModalDialog Title="Thêm hợp đồng" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tiêu đề" Required="true">
                    <BootstrapInput @bind-Value="_contractModel.Title" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Giá trị" @bind-Value="_contractModel.ContractValue" DecimalPlaces="0" />
                <AppFormField Label="Tiền tệ">
                    <BootstrapInput @bind-Value="_contractModel.Currency" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Cơ hội liên quan">
                    <Select TValue="string" @bind-Value="_contractOpportunityIdText"
                            Items="@ContractOpportunityOptions" ShowLabel="false" ShowSearch="true" />
                </AppFormField>
                <AppFormField Label="Ngày bắt đầu">
                    <DateTimePicker TValue="DateTime?" @bind-Value="_contractModel.StartDate"
                                    ShowLabel="false" DateFormat="dd/MM/yyyy" DatePlaceHolderText="Chọn ngày..." />
                </AppFormField>
                <AppFormField Label="Ngày kết thúc">
                    <DateTimePicker TValue="DateTime?" @bind-Value="_contractModel.EndDate"
                                    ShowLabel="false" DateFormat="dd/MM/yyyy" DatePlaceHolderText="Chọn ngày..." />
                </AppFormField>
                <AppFormField Label="Điều khoản thanh toán">
                    <BootstrapInput @bind-Value="_contractModel.PaymentTerms" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Điều khoản hợp đồng" Class="app-form-field-full">
                    <Textarea @bind-Value="_contractModel.Terms" ShowLabel="false" rows="3" />
                </AppFormField>
                <PendingFileAttachmentInput Label="Tệp hợp đồng" @bind-Files="_contractModel.PendingFiles" />
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseContractModalAsync" />
            <Button Text="Tạo hợp đồng" Color="Color.Primary" IsAsync="true" OnClick="CreateContractAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_activityModal" IsBackdrop="true">
    <ModalDialog Title="Thêm hoạt động" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Loại hoạt động">
                    <Select TValue="string" @bind-Value="_activityTypeText" Items="@_activityTypeOptions" ShowLabel="false" ShowSearch="true" />
                </AppFormField>
                <AppFormField Label="Tiêu đề" Required="true">
                    <BootstrapInput @bind-Value="_activityModel.Subject" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Thời gian">
                    <DateTimePicker @bind-Value="_activityModel.ActivityDate" ShowLabel="false"
                                    DateTimeFormat="dd/MM/yyyy HH:mm:ss" DateTimePlaceHolderText="Chọn ngày giờ..." />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseActivityModalAsync" />
            <Button Text="Tạo hoạt động" Color="Color.Primary" IsAsync="true" OnClick="CreateActivityAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
