@page "/crm/quotations/{Id:guid}"
@attribute [TabItemOption(Text = "Chi tiết báo giá", Icon = "fa-solid fa-file-invoice")]
@inherits CrmPageBase

<PageTitle>Chi tiết báo giá - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM / Báo giá</p>
            <h1>@(_item?.QuotationNo ?? "Chi tiết báo giá")</h1>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <Button Text="Quay lại" Color="Color.Secondary" Icon="fa-solid fa-arrow-left" OnClick="GoBack" />
            @if (_item is not null)
            {
                <Button Text="Sửa" Color="Color.Primary" Icon="fa-solid fa-pen" IsAsync="true" OnClick="ShowEditModalAsync" />
                <Button Text="Gửi" Color="Color.Info" Icon="fa-solid fa-paper-plane" IsAsync="true" OnClick="SendAsync" />
                <Button Text="Duyệt" Color="Color.Success" Icon="fa-solid fa-check" IsAsync="true" OnClick="ApproveAsync" />
                <Button Text="Tạo hợp đồng" Color="Color.Primary" Icon="fa-solid fa-file-signature" IsAsync="true" OnClick="ShowCreateContractAsync" />
                @if (Session.HasModule("SALES"))
                {
                    <Button Text="Tạo đơn hàng" Color="Color.Info" Icon="fa-solid fa-cart-shopping" OnClick="GoToSalesOrder" />
                }
                <Button Text="Từ chối" Color="Color.Warning" Icon="fa-solid fa-ban" IsAsync="true" OnClick="RejectAsync" />
            }
            <Button Text="Làm mới" Color="Color.Secondary" Icon="fa-solid fa-rotate" IsAsync="true" OnClick="LoadAsync" />
        </div>
    </header>

    @if (_loading)
    {
        <div class="app-loading">
            <Spinner Color="Color.Primary" />
            <span class="app-loading-text">Đang tải dữ liệu...</span>
        </div>
    }
    else if (_item is null)
    {
        <div class="app-empty-state">Không tìm thấy báo giá.</div>
    }
    else
    {
        <section class="app-card app-card-wide mb-3">
            <div class="app-detail-grid">
                <div><span class="app-detail-label">Tiêu đề</span><span>@(_item.Subject ?? "—")</span></div>
                <div><span class="app-detail-label">Trạng thái</span>
                    <span class="@CrmLabels.StatusBadgeClass(_item.Status)">@CrmLabels.FormatQuotationStatus(_item.Status)</span>
                </div>
                <div><span class="app-detail-label">Tạm tính</span><span>@VnMoney.Format(_item.Subtotal) @_item.Currency</span></div>
                <div><span class="app-detail-label">Chiết khấu</span><span>@VnMoney.Format(_item.DiscountAmount) @_item.Currency</span></div>
                <div><span class="app-detail-label">Thuế</span><span>@VnMoney.Format(_item.TaxAmount) @_item.Currency</span></div>
                <div><span class="app-detail-label">Tổng tiền</span><span>@_item.TotalAmount.ToString("N0") @_item.Currency</span></div>
                <div><span class="app-detail-label">Hiệu lực đến</span><span>@(_item.ValidUntil?.ToString("dd/MM/yyyy") ?? "—")</span></div>
                <div><span class="app-detail-label">Ngày duyệt</span><span>@(_item.ApprovedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</span></div>
                <div><span class="app-detail-label">Ngày tạo</span><span>@_item.CreationTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span></div>
            </div>
        </section>

        <div class="crm-related-grid mb-3">
            @if (_customer is not null)
            {
                <button class="app-card crm-related-summary" type="button" @onclick="@(() => OpenCustomer(_customer.Id))">
                    <span class="app-detail-label">Khách hàng</span>
                    <strong>@_customer.Code - @_customer.Name</strong>
                    <span>@(_customer.Email ?? _customer.Phone ?? "Mở chi tiết khách hàng")</span>
                </button>
            }
            @if (_opportunity is not null)
            {
                <button class="app-card crm-related-summary" type="button" @onclick="@(() => OpenOpportunity(_opportunity.Id))">
                    <span class="app-detail-label">Cơ hội</span>
                    <strong>@_opportunity.Name</strong>
                    <span>@VnMoney.Format(_opportunity.Amount) @_opportunity.Currency / @CrmLabels.FormatOpportunityStage(_opportunity.Stage)</span>
                </button>
            }
        </div>

        <Card HeaderText="Chi tiết dòng hàng" IsShadow="true">
            <BodyTemplate>
                @if (!_item.Lines.Any())
                {
                    <div class="app-empty-state">Chưa có dòng hàng.</div>
                }
                else
                {
                    <Table TItem="QuotationLineDto" Items="@_item.Lines.ToList()" IsPagination="false" IsStriped="true" IsBordered="true">
                        <TableColumns>
                            <TableColumn @bind-Field="@context.LineNo" Text="#" />
                            <TableColumn @bind-Field="@context.ProductCode" Text="Mã SP" />
                            <TableColumn @bind-Field="@context.ProductName" Text="Tên SP" />
                            <TableColumn @bind-Field="@context.Quantity" Text="SL" />
                            <TableColumn @bind-Field="@context.UnitPrice" Text="Đơn giá">
                                <Template Context="v">@v.Row.UnitPrice.ToString("N0")</Template>
                            </TableColumn>
                            <TableColumn @bind-Field="@context.LineTotal" Text="Thành tiền">
                                <Template Context="v">@v.Row.LineTotal.ToString("N0")</Template>
                            </TableColumn>
                        </TableColumns>
                    </Table>
                }
            </BodyTemplate>
        </Card>

        <section class="app-card app-card-wide mt-3">
            <h3>Hợp đồng tạo từ báo giá</h3>
            @if (!_contracts.Any())
            {
                <div class="app-empty-state">Chưa có hợp đồng liên quan.</div>
            }
            else
            {
                @foreach (var item in _contracts.Take(6))
                {
                    <button class="crm-related-row crm-related-button" type="button" @onclick="@(() => OpenContract(item.Id))">
                        <div>
                            <strong>@item.ContractNo</strong>
                            <span>@VnMoney.Format(item.ContractValue) @item.Currency</span>
                        </div>
                        <span class="@CrmLabels.StatusBadgeClass(item.Status)">@CrmLabels.FormatContractStatus(item.Status)</span>
                    </button>
                }
            }
        </section>

        <div class="mt-3">
            <FileAttachmentPanel Module="CRM" EntityType="Quotation" EntityId="@_item.Id.ToString()"
                                 Title="Chứng từ báo giá"
                                 WarningText="Chưa có chứng từ báo giá. Vui lòng tải lên file báo giá." />
        </div>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="Sửa báo giá" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tiêu đề">
                    <BootstrapInput @bind-Value="_editModel.Subject" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Chiết khấu" @bind-Value="_editModel.DiscountAmount" DecimalPlaces="0" />
                <AppFormField Label="Chiết khấu (%)">
                    <BootstrapInputNumber @bind-Value="_editModel.DiscountPercent" ShowLabel="false" />
                </AppFormField>
                <ProductLinesEditor Label="Dòng sản phẩm" @bind-Lines="_editModel.Lines" />
                <AppFormField Label="Ghi chú" Class="app-form-field-full">
                    <Textarea @bind-Value="_editModel.Notes" ShowLabel="false" rows="3" />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseEditModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveEditAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

<Modal @ref="_contractModal" IsBackdrop="true">
    <ModalDialog Title="Tạo hợp đồng từ báo giá" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="Tiêu đề" Required="true">
                    <BootstrapInput @bind-Value="_contractModel.Title" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Giá trị hợp đồng" @bind-Value="_contractModel.ContractValue" DecimalPlaces="0" />
                <AppFormField Label="Ngày bắt đầu">
                    <DateTimePicker TValue="DateTime?" @bind-Value="_contractModel.StartDate"
                                    ShowLabel="false" DateFormat="yyyy-MM-dd" />
                </AppFormField>
                <AppFormField Label="Ngày kết thúc">
                    <DateTimePicker TValue="DateTime?" @bind-Value="_contractModel.EndDate"
                                    ShowLabel="false" DateFormat="yyyy-MM-dd" />
                </AppFormField>
                <AppFormField Label="Điều khoản thanh toán">
                    <BootstrapInput @bind-Value="_contractModel.PaymentTerms" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Điều khoản hợp đồng" Class="app-form-field-full">
                    <Textarea @bind-Value="_contractModel.Terms" ShowLabel="false" rows="3" />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseContractModalAsync" />
            <Button Text="Tạo hợp đồng" Color="Color.Primary" IsAsync="true" OnClick="CreateContractAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
