@page "/crm/quotations"
@attribute [TabItemOption(Text = "Báo giá", Icon = "fa-solid fa-file-invoice")]
@inherits CrmPageBase

<PageTitle>Báo giá - CRM</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">CRM</p>
            <h1>Báo giá</h1>
            <p>Quản lý báo giá khách hàng trong tenant hiện tại.</p>
        </div>
    </header>

    @if (!Can(NexusPermissions.Crm.Quotations.View))
    {
        <div class="app-alert">@AccessDeniedMessage</div>
    }
    else if (!HasCrmModule)
    {
        <div class="app-alert">Tenant này chưa được bật module CRM.</div>
    }
    else
    {
        <Card HeaderText="Danh sách báo giá" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="QuotationDto" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
                       ShowEditButton="false" ShowDeleteButton="false"
                       ShowExtendEditButton="false" ShowExtendDeleteButton="false"
                       ExtendButtonColumnWidth="220"
                       ShowSearch="true" ShowSearchText="true" ShowRefresh="true" ShowAdvancedSearch="false">
                    <TableToolbarTemplate>
                        @if (Can(NexusPermissions.Crm.Quotations.Create))
                        {
                            <TableToolbarButton TItem="QuotationDto" Color="Color.Primary" Icon="fa-solid fa-plus"
                                            Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                        }
                    </TableToolbarTemplate>
                    <RowButtonTemplate>
                        <TableCellButton Color="Color.Info" Icon="fa-solid fa-eye" Text="Chi tiết"
                                         OnClick="@(() => ViewDetailAsync(context.Id))" />
                        @if (Can(NexusPermissions.Crm.Quotations.Edit))
                        {
                            <TableCellButton Color="Color.Primary" Icon="fa-solid fa-pen" Text="Sửa"
                                         OnClick="@(() => ShowEditAsync(context))" />
                        }
                        @if (Can(NexusPermissions.Crm.Quotations.Approve))
                        {
                            <TableCellButton Color="Color.Success" Icon="fa-solid fa-check" Text="Duyệt"
                                         IsDisabled="@(context.Status == QuotationStatus.Approved)"
                                         OnClick="@(() => ApproveAsync(context.Id))" />
                        }
                        @if (Can(NexusPermissions.Crm.Quotations.Delete))
                        {
                            <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá"
                                         OnClick="@(() => DeleteAsync(context.Id))" />
                        }
                    </RowButtonTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.QuotationNo" Text="Số BG" Sortable="true" Searchable="true">
                            <Template Context="v">
                                <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => ViewDetailAsync(v.Row.Id))">
                                    @v.Row.QuotationNo
                                </button>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.CustomerId" Text="Khách hàng">
                            <Template Context="v">
                                <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => ViewCustomerDetail(v.Row.CustomerId))">
                                    @CustomerName(v.Row.CustomerId)
                                </button>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Subject" Text="Tiêu đề" Searchable="true" />
                        <TableColumn @bind-Field="@context.OpportunityId" Text="Cơ hội">
                            <Template Context="v">
                                @if (v.Row.OpportunityId.HasValue)
                                {
                                    <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => ViewOpportunityDetail(v.Row.OpportunityId.Value))">
                                        Mở cơ hội
                                    </button>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Status" Text="Trạng thái" Sortable="true">
                            <Template Context="v">
                                <span class="@CrmLabels.StatusBadgeClass(v.Row.Status)">@CrmLabels.FormatQuotationStatus(v.Row.Status)</span>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.DiscountAmount" Text="Chiết khấu">
                            <Template Context="v">@VnMoney.Format(v.Row.DiscountAmount)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.TaxAmount" Text="Thuế">
                            <Template Context="v">@VnMoney.Format(v.Row.TaxAmount)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.TotalAmount" Text="Tổng tiền" Sortable="true">
                            <Template Context="v">@VnMoney.Format(v.Row.TotalAmount) @v.Row.Currency</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.ValidUntil" Text="Hiệu lực đến">
                            <Template Context="v">@(v.Row.ValidUntil?.ToString("dd/MM/yyyy") ?? "—")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.CreationTime" Text="Ngày tạo" Sortable="true">
                            <Template Context="v">@v.Row.CreationTime.ToLocalTime().ToString("dd/MM/yyyy")</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="@_modalTitle" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            <div class="app-form-grid">
                <CustomerLookupSelect Label="Khách hàng" Required="true" @bind-Value="_customerIdText" />
                <ContactLookupSelect Label="Liên hệ" CustomerId="@_customerIdText" @bind-Value="_contactIdText" />
                <AppFormField Label="Số báo giá">
                    @if (_isCreate)
                    {
                        <BootstrapInput Value="@("(tự động)")" ShowLabel="false" IsDisabled="true" />
                    }
                    else
                    {
                        <BootstrapInput @bind-Value="_model.QuotationNo" ShowLabel="false" IsDisabled="true" />
                    }
                </AppFormField>
                <AppFormField Label="Tiêu đề">
                    <BootstrapInput @bind-Value="_model.Subject" ShowLabel="false" />
                </AppFormField>
                <ProductLinesEditor Label="Dòng sản phẩm" @bind-Lines="_model.Lines" />
                @if (_isCreate)
                {
                    <PendingFileAttachmentInput Label="Tệp báo giá" @bind-Files="_model.PendingFiles" />
                }
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseModalAsync" />
            <Button Text="Lưu" Color="Color.Primary" IsAsync="true" OnClick="SaveAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>
