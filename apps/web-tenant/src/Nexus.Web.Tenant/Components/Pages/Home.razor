@page "/"
@attribute [TabItemOption(Text = "Tổng quan", Icon = "fa-solid fa-gauge-high", Closable = false)]
@inject TenantSessionService Session

<PageTitle>Nexus Tenant</PageTitle>

<section class="page-header">
    <div>
        <h1>@(Session.Tenant?.Name ?? "Nexus Tenant")</h1>
        <p>@(Session.IsAuthenticated ? "Vận hành các module nghiệp vụ đã được cấp cho tenant hiện tại." : "Đăng nhập để tải module và quyền truy cập tenant.")</p>
    </div>
    <a class="btn btn-primary" href="@(Session.IsAuthenticated ? "crm/customers" : "login")">
        @(Session.IsAuthenticated ? "Mở CRM" : "Đăng nhập")
    </a>
</section>

<div class="row g-3 mb-3">
    @foreach (var tile in Tiles)
    {
        <div class="col-12 col-sm-6 col-xl-3">
            <Card IsShadow="true" class="dashboard-tile h-100">
                <BodyTemplate>
                    <div class="d-flex align-items-center">
                        <span class="dashboard-tile-icon">
                            <i class="@tile.Icon"></i>
                        </span>
                        <div class="ms-3">
                            <strong class="d-block">@tile.Value</strong>
                            <span class="text-muted small">@tile.Label</span>
                        </div>
                    </div>
                </BodyTemplate>
            </Card>
        </div>
    }
</div>

<div class="row g-3">
    <div class="col-12 col-xl-8">
        <Card IsShadow="true" class="h-100">
            <HeaderTemplate>
                <strong>Module nghiệp vụ</strong>
            </HeaderTemplate>
            <BodyTemplate>
                @if (!Session.IsAuthenticated)
                {
                    <div class="app-empty-state">Đăng nhập để tải quyền truy cập module nghiệp vụ.</div>
                }
                else if (Session.EnabledModules.Count == 0)
                {
                    <div class="app-empty-state">Tenant này chưa bật module nào.</div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var module in Session.EnabledModules)
                        {
                            <div class="col-12 col-md-6">
                                <a class="text-decoration-none" href="@ModuleUrl(module)">
                                    <div class="module-choice">
                                        <span class="dashboard-tile-icon">
                                            <i class="@ModuleIcon(module)"></i>
                                        </span>
                                        <div>
                                            <strong>@ModuleTitle(module)</strong>
                                            <small>@ModuleDescription(module)</small>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
            </BodyTemplate>
        </Card>
    </div>
    <div class="col-12 col-xl-4">
        <Card IsShadow="true" class="h-100">
            <HeaderTemplate>
                <strong>Thao tác nhanh</strong>
            </HeaderTemplate>
            <BodyTemplate>
                <div class="quick-link-list">
                    <a href="tenant-users"><i class="fa-solid fa-users"></i>Quản lý người dùng</a>
                    <a href="tenant-permissions"><i class="fa-solid fa-user-shield"></i>Phân quyền vai trò</a>
                    <a href="reports"><i class="fa-solid fa-chart-line"></i>Báo cáo</a>
                    <a href="settings"><i class="fa-solid fa-gear"></i>Thiết lập tenant</a>
                </div>
            </BodyTemplate>
        </Card>
    </div>
</div>

@code {
    private (string Label, string Value, string Icon)[] Tiles =>
    [
        ("Module đã bật", Session.EnabledModules.Count.ToString(), "fa-solid fa-cubes"),
        ("Mã tenant", Session.Tenant?.Code ?? "-", "fa-solid fa-building"),
        ("Người dùng", Session.UserName ?? "-", "fa-solid fa-user"),
        ("Trạng thái", Session.Tenant?.Status ?? "Chưa đăng nhập", "fa-solid fa-circle-check"),
    ];

    private static string ModuleUrl(string module) => module.ToUpperInvariant() switch
    {
        "CRM" => "crm/customers",
        "SALES" => "sales/orders",
        _ => "settings"
    };

    private static string ModuleIcon(string module) => module.ToUpperInvariant() switch
    {
        "CRM" => "fa-solid fa-address-book",
        "SALES" => "fa-solid fa-cart-shopping",
        _ => "fa-solid fa-cube"
    };

    private static string ModuleTitle(string module) => module.ToUpperInvariant() switch
    {
        "SALES" => "Bán hàng",
        _ => module
    };

    private static string ModuleDescription(string module) => module.ToUpperInvariant() switch
    {
        "CRM" => "Khách hàng, lead, báo giá và hợp đồng",
        "SALES" => "Đơn hàng, duyệt đơn và hoàn tất",
        _ => "Module nghiệp vụ đã bật"
    };
}
