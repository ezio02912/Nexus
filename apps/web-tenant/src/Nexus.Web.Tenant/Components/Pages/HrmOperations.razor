@inject TenantPortalApiClient Api
@inject FileApiClient FileApi
@inject TenantSessionService Session
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject SwalService SwalService

<PageTitle>@Definition.Title</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">HRM</p>
            <h1>@Definition.Title</h1>
            <p>@Definition.Description</p>
        </div>
    </header>

    @if (!Session.HasModule("HRM"))
    {
        <div class="app-alert">Tenant này chưa được bật module Nhân sự.</div>
    }
    else if (!Session.IsGranted(Definition.ViewPermission))
    {
        <div class="app-alert">Bạn không có quyền xem màn hình này.</div>
    }
    else
    {
        <Card HeaderText="@Definition.Title" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="OperationRow" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="true"
                       ShowEditButton="false" ShowDeleteButton="false"
                       ShowExtendEditButton="false" ShowExtendDeleteButton="false"
                       ExtendButtonColumnWidth="150"
                       ShowSearch="true" ShowSearchText="true" ShowRefresh="true" ShowAdvancedSearch="false">
                    <TableToolbarTemplate>
                        <TableToolbarButton TItem="OperationRow" Color="Color.Primary" Icon="fa-solid fa-plus" Text="Thêm mới" OnClickCallback="ShowCreateAsync" />
                    </TableToolbarTemplate>
                    <RowButtonTemplate>
                        <TableCellButton Color="Color.Primary" Icon="fa-solid fa-pen" Text="Sửa" OnClick="@(() => ShowEditAsync(context))" />
                        <TableCellButton Color="Color.Danger" Icon="fa-solid fa-trash" Text="Xoá" OnClick="@(() => DeleteAsync(context))" />
                        @if (context.Kind == "offers" && context.Status.Equals("Draft", StringComparison.OrdinalIgnoreCase))
                        {
                            <TableCellButton Color="Color.Success" Icon="fa-solid fa-check" Text="Nhận việc" OnClick="@(() => AcceptOfferAsync(context.Id))" />
                        }
                    </RowButtonTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.Code" Text="Mã/Số" Sortable="true" Searchable="true">
                            <Template Context="v"><span class="app-table-link-code">@v.Row.Code</span></Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Name" Text="Tên/Nội dung" Sortable="true" Searchable="true" />
                        <TableColumn @bind-Field="@context.Status" Text="Trạng thái" Sortable="true">
                            <Template Context="v"><span class="@StatusCss(v.Row.Status)">@StatusText(v.Row.Status)</span></Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Amount" Text="Giá trị" Sortable="true">
                            <Template Context="v">@FormatAmount(v.Row.Amount, v.Row.Currency)</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.Extra" Text="Thông tin nghiệp vụ" Searchable="true" />
                        <TableColumn @bind-Field="@context.UpdatedAt" Text="Cập nhật" Sortable="true">
                            <Template Context="v">@v.Row.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_editModal" IsBackdrop="true">
    <ModalDialog Title="@_dialogTitle" Size="Size.Large" ShowCloseButton="true">
        <BodyTemplate>
            <div class="app-form-grid">
                <AppFormField Label="@CodeLabel" Required="true">
                    <BootstrapInput @bind-Value="_form.Code" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="@NameLabel" Required="true">
                    <BootstrapInput @bind-Value="_form.Name" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Trạng thái">
                    <Select TValue="string" @bind-Value="_form.Status" Items="@StatusOptions" ShowLabel="false" />
                </AppFormField>
                @if (Definition.Kind is "employees" or "profiles" or "dashboard")
                {
                    <AppFormField Label="Phòng ban">
                        <Select TValue="string" @bind-Value="_form.DepartmentIdText" Items="@_departmentOptions" ShowLabel="false" ShowSearch="true" />
                    </AppFormField>
                    <AppFormField Label="Chức vụ">
                        <Select TValue="string" @bind-Value="_form.PositionIdText" Items="@_positionOptions" ShowLabel="false" ShowSearch="true" />
                    </AppFormField>
                    <AppFormField Label="Cấp trên trực tiếp">
                        <Select TValue="string" @bind-Value="_form.ManagerIdText" Items="@_managerOptions" ShowLabel="false" ShowSearch="true" />
                    </AppFormField>
                    <AppFormField Label="Loại lao động">
                        <Select TValue="string" @bind-Value="_form.EmploymentType" Items="@_employmentTypeOptions" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Level">
                        <BootstrapInput @bind-Value="_form.JobLevel" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Cấp bậc">
                        <BootstrapInput @bind-Value="_form.JobGrade" ShowLabel="false" />
                    </AppFormField>
                    <AppMoneyInput Label="Lương thử việc" @bind-Value="_form.ProbationSalary" DecimalPlaces="0" />
                    <AppMoneyInput Label="Lương chính thức" @bind-Value="_form.OfficialSalary" DecimalPlaces="0" />
                    <AppMoneyInput Label="Lương cơ bản" @bind-Value="_form.Amount" DecimalPlaces="0" />
                    <AppFormField Label="Thưởng hiệu suất (%)">
                        <BootstrapInputNumber @bind-Value="_form.PerformanceBonusPercent" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Bắt đầu thử việc">
                        <DateTimePicker TValue="DateTime?" @bind-Value="_form.ProbationStartDate" ShowLabel="false" DateTimeFormat="dd/MM/yyyy" />
                    </AppFormField>
                    <AppFormField Label="Kết thúc thử việc">
                        <DateTimePicker TValue="DateTime?" @bind-Value="_form.ProbationEndDate" ShowLabel="false" DateTimeFormat="dd/MM/yyyy" />
                    </AppFormField>
                    <PendingFileAttachmentInput Label="Ảnh nhân viên, bằng cấp, hợp đồng, hồ sơ" @bind-Files="_employeeFiles" />
                }
                else if (Definition.Kind == "departments")
                {
                    <AppFormField Label="Phòng ban cha">
                        <Select TValue="string" @bind-Value="_form.ParentDepartmentIdText" Items="@_departmentOptions" ShowLabel="false" ShowSearch="true" />
                    </AppFormField>
                    <AppFormField Label="Trưởng phòng">
                        <Select TValue="string" @bind-Value="_form.ManagerIdText" Items="@_managerOptions" ShowLabel="false" ShowSearch="true" />
                    </AppFormField>
                    <AppFormField Label="Cost center">
                        <BootstrapInput @bind-Value="_form.CostCenterCode" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Địa điểm">
                        <BootstrapInput @bind-Value="_form.Location" ShowLabel="false" />
                    </AppFormField>
                }
                else if (Definition.Kind == "positions")
                {
                    <AppFormField Label="Phòng ban">
                        <Select TValue="string" @bind-Value="_form.DepartmentIdText" Items="@_departmentOptions" ShowLabel="false" ShowSearch="true" />
                    </AppFormField>
                    <AppFormField Label="Level">
                        <BootstrapInput @bind-Value="_form.JobLevel" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Job grade">
                        <BootstrapInput @bind-Value="_form.JobGrade" ShowLabel="false" />
                    </AppFormField>
                    <AppMoneyInput Label="Lương tối thiểu" @bind-Value="_form.MinSalary" DecimalPlaces="0" />
                    <AppMoneyInput Label="Lương tối đa" @bind-Value="_form.Amount" DecimalPlaces="0" />
                }
                else
                {
                    <AppMoneyInput Label="@AmountLabel" @bind-Value="_form.Amount" DecimalPlaces="0" />
                }
                <AppFormField Label="Ngày bắt đầu">
                    <DateTimePicker TValue="DateTime?" @bind-Value="_form.StartDate" ShowLabel="false" DateTimeFormat="dd/MM/yyyy" />
                </AppFormField>
                <AppFormField Label="Ngày kết thúc">
                    <DateTimePicker TValue="DateTime?" @bind-Value="_form.EndDate" ShowLabel="false" DateTimeFormat="dd/MM/yyyy" />
                </AppFormField>
                <AppFormField Label="Thông tin thêm" Class="app-form-field-full">
                    <Textarea @bind-Value="_form.Extra" ShowLabel="false" rows="3" />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="@(() => _editModal!.Close())" />
            <Button Text="Lưu" Color="Color.Primary" Icon="fa-solid fa-floppy-disk" IsAsync="true" OnClick="SaveAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

@code {
    private static readonly int[] PageItems = [10, 20, 50];
    private Table<OperationRow>? _table;
    private Modal? _editModal;
    private HrmFormModel _form = new();
    private List<PendingFileAttachment> _employeeFiles = [];
    private IReadOnlyList<HrmEmployeeRecord> _employees = [];
    private IReadOnlyList<HrmDepartmentRecord> _departments = [];
    private IReadOnlyList<HrmPositionRecord> _positions = [];
    private IReadOnlyList<HrmContractRecord> _contracts = [];
    private List<SelectedItem> _departmentOptions = [new("", "Chọn phòng ban...")];
    private List<SelectedItem> _positionOptions = [new("", "Chọn chức vụ...")];
    private List<SelectedItem> _managerOptions = [new("", "Chọn cấp trên...")];
    private readonly List<SelectedItem> _employmentTypeOptions =
    [
        new("FullTime", "Toàn thời gian"),
        new("PartTime", "Bán thời gian"),
        new("Outsource", "Outsource"),
        new("Probation", "Thử việc"),
        new("Intern", "Thực tập")
    ];
    private string _dialogTitle = "";

    private HrmDefinition Definition => ResolveDefinition();
    private string CodeLabel => Definition.Kind switch { "employees" or "profiles" or "dashboard" => "Mã nhân viên", "departments" => "Mã phòng ban", "positions" => "Mã chức vụ", "contracts" => "Số hợp đồng", "recruitment" => "Mã/Số", _ => "Mã" };
    private string NameLabel => Definition.Kind switch { "employees" or "profiles" or "dashboard" => "Họ tên", "departments" => "Tên phòng ban", "positions" => "Tên chức vụ", "contracts" => "Loại hợp đồng", "recruitment" => "Tiêu đề/Họ tên", _ => "Tên" };
    private string AmountLabel => Definition.Kind switch { "positions" => "Lương tối đa", "contracts" => "Lương cơ bản", "recruitment" => "Ngân sách/Lương", _ => "Lương/Giá trị" };
    private List<SelectedItem> StatusOptions => Definition.Kind switch
    {
        "employees" or "profiles" or "dashboard" => [new("Draft", "Nháp"), new("Probation", "Thử việc"), new("Official", "Chính thức"), new("Outsource", "Outsource"), new("PartTime", "Part-time"), new("Suspended", "Tạm ngưng"), new("Resigned", "Nghỉ việc")],
        "departments" or "positions" => [new("Active", "Hoạt động"), new("Inactive", "Ngừng dùng")],
        "contracts" => [new("Draft", "Nháp"), new("Signed", "Đã ký"), new("Completed", "Đã hoàn thành"), new("Terminated", "Đã chấm dứt")],
        _ => [new("Open", "Đang mở"), new("Draft", "Nháp"), new("Accepted", "Đã nhận"), new("Rejected", "Từ chối"), new("Closed", "Đã đóng")]
    };

    private async Task<QueryData<OperationRow>> OnQueryAsync(QueryPageOptions options)
    {
        if (Session.TenantId is not Guid tenantId || !Session.HasModule("HRM") || !Session.IsGranted(Definition.ViewPermission))
        {
            return new QueryData<OperationRow> { Items = [], TotalCount = 0 };
        }

        try
        {
            var rows = await LoadRowsAsync(tenantId, options.SearchText);
            var items = rows.Skip((options.PageIndex - 1) * options.PageItems).Take(options.PageItems).ToList();
            return new QueryData<OperationRow>
            {
                Items = items,
                TotalCount = rows.Count,
                IsSearch = !string.IsNullOrWhiteSpace(options.SearchText),
                IsFiltered = !string.IsNullOrWhiteSpace(options.SearchText)
            };
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            return new QueryData<OperationRow> { Items = [], TotalCount = 0 };
        }
    }

    private async Task<List<OperationRow>> LoadRowsAsync(Guid tenantId, string? search)
    {
        await LoadLookupsAsync(tenantId);

        if (Definition.Kind == "employees" || Definition.Kind == "profiles" || Definition.Kind == "dashboard")
        {
            var items = await Api.GetHrmEmployeesAsync(tenantId, search) ?? [];
            _employees = items;
            return items.Select(x => new OperationRow(x.Id, x.EmployeeCode, x.FullName, x.EmploymentStatus, x.BaseSalary, x.SalaryCurrency, $"{DepartmentName(x.DepartmentId)} | {PositionName(x.PositionId)} | {ManagerName(x.ManagerId)} | {x.EmploymentType}", x.UpdatedAt)).ToList();
        }

        if (Definition.Kind == "departments")
        {
            var items = await Api.GetHrmDepartmentsAsync(tenantId, search) ?? [];
            _departments = items;
            return items.Select(x => new OperationRow(x.Id, x.DepartmentCode, x.Name, x.Status, 0, "VND", $"Cha: {DepartmentName(x.ParentDepartmentId)} | Quản lý: {ManagerName(x.ManagerId)} | {x.CostCenterCode} | {x.Location}", x.UpdatedAt)).ToList();
        }

        if (Definition.Kind == "positions")
        {
            var items = await Api.GetHrmPositionsAsync(tenantId, search) ?? [];
            _positions = items;
            return items.Select(x => new OperationRow(x.Id, x.PositionCode, x.Name, x.Status, x.MaxSalary, "VND", $"{DepartmentName(x.DepartmentId)} | {x.Level} | {x.JobGrade} | {FormatAmount(x.MinSalary, "VND")} - {FormatAmount(x.MaxSalary, "VND")}", x.UpdatedAt)).ToList();
        }

        if (Definition.Kind == "contracts")
        {
            var items = await Api.GetHrmContractsAsync(tenantId, search) ?? [];
            return items.Select(x => new OperationRow(x.Id, x.ContractNo, x.ContractType, x.Status, x.BaseSalary + x.AllowanceAmount, x.Currency, $"{DateText(x.EffectiveFrom)} - {DateText(x.EffectiveTo)} | {x.WorkingLocation}", x.UpdatedAt)).ToList();
        }

        if (Definition.Kind == "recruitment")
        {
            var reqs = await Api.GetHrmRequisitionsAsync(tenantId, search) ?? [];
            var candidates = await Api.GetHrmCandidatesAsync(tenantId, search) ?? [];
            var apps = await Api.GetHrmApplicationsAsync(tenantId, search) ?? [];
            var offers = await Api.GetHrmOffersAsync(tenantId, search) ?? [];
            return reqs.Select(x => new OperationRow(x.Id, x.RequisitionNo, x.Title, x.Status, x.SalaryMax, "VND", $"{x.Headcount} vị trí | {x.WorkLocation} | {x.EmploymentType}", x.UpdatedAt))
                .Concat(candidates.Select(x => new OperationRow(x.Id, x.CandidateCode, x.FullName, x.Status, x.ExpectedSalary, x.Currency, $"{x.Email} | {x.Phone} | {x.Source}", x.UpdatedAt)))
                .Concat(apps.Select(x => new OperationRow(x.Id, x.Id.ToString("N")[..8], x.Stage, x.Status, x.OfferSalary, "VND", $"Screen {x.ScreeningScore} | Interview {x.InterviewScore}", x.UpdatedAt)))
                .Concat(offers.Select(x => new OperationRow(x.Id, x.OfferNo, "Offer", x.Status, x.OfferedSalary, x.Currency, $"Ngày bắt đầu {DateText(x.StartDate)}", x.UpdatedAt, "offers")))
                .OrderByDescending(x => x.UpdatedAt)
                .ToList();
        }

        var offerItems = await Api.GetHrmOffersAsync(tenantId, search) ?? [];
        return offerItems.Select(x => new OperationRow(x.Id, x.OfferNo, "Onboarding từ offer", x.Status, x.OfferedSalary, x.Currency, $"Accepted {DateTimeText(x.AcceptedAt)}", x.UpdatedAt, "offers")).ToList();
    }

    private async Task AcceptOfferAsync(Guid id)
    {
        try
        {
            await Api.AcceptHrmOfferAsync(id);
            await ToastService.Success("Thành công", "Offer đã được nhận, hệ thống đã tạo nhân viên draft và checklist onboarding.");
            if (_table is not null)
            {
                await _table.QueryAsync();
            }
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private async Task ShowCreateAsync(IEnumerable<OperationRow> _)
    {
        if (Session.TenantId is Guid tenantId)
        {
            await LoadLookupsAsync(tenantId);
        }

        _dialogTitle = $"Thêm {Definition.Title.ToLowerInvariant()}";
        _employeeFiles = [];
        _form = new HrmFormModel { Status = DefaultStatus(), Currency = "VND", EmploymentType = "FullTime" };
        await _editModal!.Show();
    }

    private async Task ShowEditAsync(OperationRow row)
    {
        if (Session.TenantId is Guid tenantId)
        {
            await LoadLookupsAsync(tenantId);
        }

        _dialogTitle = $"Sửa {Definition.Title.ToLowerInvariant()}";
        _employeeFiles = [];
        _form = BuildForm(row);
        await _editModal!.Show();
    }

    private HrmFormModel BuildForm(OperationRow row)
    {
        if (Definition.Kind is "employees" or "profiles" or "dashboard")
        {
            var employee = _employees.FirstOrDefault(x => x.Id == row.Id);
            if (employee is not null)
            {
                return new HrmFormModel
                {
                    Id = employee.Id,
                    Code = employee.EmployeeCode,
                    Name = employee.FullName,
                    Status = employee.EmploymentStatus,
                    Amount = employee.BaseSalary,
                    Currency = employee.SalaryCurrency,
                    DepartmentIdText = employee.DepartmentId?.ToString() ?? "",
                    PositionIdText = employee.PositionId?.ToString() ?? "",
                    ManagerIdText = employee.ManagerId?.ToString() ?? "",
                    EmploymentType = string.IsNullOrWhiteSpace(employee.EmploymentType) ? "FullTime" : employee.EmploymentType,
                    JobLevel = employee.JobLevel,
                    JobGrade = employee.JobGrade,
                    ProbationSalary = employee.ProbationSalary,
                    OfficialSalary = employee.OfficialSalary,
                    PerformanceBonusPercent = employee.PerformanceBonusPercent,
                    StartDate = ToDateTime(employee.JoinDate),
                    ProbationStartDate = ToDateTime(employee.ProbationStartDate),
                    ProbationEndDate = ToDateTime(employee.ProbationEndDate),
                    EndDate = ToDateTime(employee.ResignDate),
                    Extra = employee.Notes
                };
            }
        }

        if (Definition.Kind == "departments")
        {
            var department = _departments.FirstOrDefault(x => x.Id == row.Id);
            if (department is not null)
            {
                return new HrmFormModel
                {
                    Id = department.Id,
                    Code = department.DepartmentCode,
                    Name = department.Name,
                    Status = department.Status,
                    ParentDepartmentIdText = department.ParentDepartmentId?.ToString() ?? "",
                    ManagerIdText = department.ManagerId?.ToString() ?? "",
                    CostCenterCode = department.CostCenterCode,
                    Location = department.Location,
                    Extra = department.Description
                };
            }
        }

        if (Definition.Kind == "positions")
        {
            var position = _positions.FirstOrDefault(x => x.Id == row.Id);
            if (position is not null)
            {
                return new HrmFormModel
                {
                    Id = position.Id,
                    Code = position.PositionCode,
                    Name = position.Name,
                    Status = position.Status,
                    Amount = position.MaxSalary,
                    MinSalary = position.MinSalary,
                    DepartmentIdText = position.DepartmentId?.ToString() ?? "",
                    JobLevel = position.Level,
                    JobGrade = position.JobGrade,
                    Extra = position.Description
                };
            }
        }

        return new HrmFormModel
        {
            Id = row.Id,
            Code = row.Code,
            Name = row.Name,
            Status = row.Status,
            Amount = row.Amount,
            Currency = row.Currency,
            Extra = row.Extra
        };
    }

    private async Task SaveAsync()
    {
        if (Session.TenantId is not Guid tenantId || string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            await ShowErrorAsync(new InvalidOperationException("Vui lòng nhập đầy đủ mã và tên."));
            return;
        }

        try
        {
            var savedId = await UpsertAsync(tenantId);
            if (savedId is Guid employeeId && Definition.Kind is "employees" or "profiles" or "dashboard" && _employeeFiles.Count > 0)
            {
                await FileApi.UploadAndLinkAsync(_employeeFiles, "HRM", "Employee", employeeId.ToString(), "EmployeeProfile");
            }

            await ToastService.Success("Thành công", "Đã lưu dữ liệu.");
            await _editModal!.Close();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private async Task DeleteAsync(OperationRow row)
    {
        if (Session.TenantId is not Guid tenantId)
        {
            return;
        }

        try
        {
            await Api.DeleteHrmEntityAsync(DeleteEndpoint(), tenantId, row.Id);
            await ToastService.Success("Đã xoá", "Đã xoá dữ liệu.");
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private Task ReloadAsync() => _table is null ? Task.CompletedTask : _table.QueryAsync();

    private async Task LoadLookupsAsync(Guid tenantId)
    {
        _departments = await Api.GetHrmDepartmentsAsync(tenantId) ?? [];
        _positions = await Api.GetHrmPositionsAsync(tenantId) ?? [];
        _employees = await Api.GetHrmEmployeesAsync(tenantId) ?? [];

        _departmentOptions =
        [
            new("", "Chọn phòng ban..."),
            .. _departments.Select(x => new SelectedItem(x.Id.ToString(), $"{x.DepartmentCode} - {x.Name}"))
        ];
        _positionOptions =
        [
            new("", "Chọn chức vụ..."),
            .. _positions.Select(x => new SelectedItem(x.Id.ToString(), $"{x.PositionCode} - {x.Name}"))
        ];
        _managerOptions =
        [
            new("", "Chọn cấp trên..."),
            .. _employees.Select(x => new SelectedItem(x.Id.ToString(), $"{x.EmployeeCode} - {x.FullName}"))
        ];
    }

    private async Task<Guid?> UpsertAsync(Guid tenantId)
    {
        var id = _form.Id;
        var now = DateTimeOffset.UtcNow;
        switch (Definition.Kind)
        {
            case "employees":
            case "profiles":
            case "dashboard":
                var employee = await Api.UpsertHrmEmployeeAsync(new HrmEmployeeRecord { Id = id, TenantId = tenantId, EmployeeCode = _form.Code.Trim(), FullName = _form.Name.Trim(), DisplayName = _form.Name.Trim(), DepartmentId = ParseGuid(_form.DepartmentIdText), PositionId = ParseGuid(_form.PositionIdText), ManagerId = ParseGuid(_form.ManagerIdText), JobLevel = _form.JobLevel.Trim(), JobGrade = _form.JobGrade.Trim(), EmploymentStatus = BlankDefault(_form.Status, "Draft"), EmploymentType = BlankDefault(_form.EmploymentType, "FullTime"), JoinDate = ToDateOnly(_form.StartDate), ProbationStartDate = ToDateOnly(_form.ProbationStartDate), ProbationEndDate = ToDateOnly(_form.ProbationEndDate), ResignDate = ToDateOnly(_form.EndDate), ProbationSalary = _form.ProbationSalary, OfficialSalary = _form.OfficialSalary, BaseSalary = _form.Amount, PerformanceBonusPercent = _form.PerformanceBonusPercent, SalaryCurrency = "VND", Notes = _form.Extra ?? "", UpdatedAt = now });
                return employee?.Id ?? id;
            case "departments":
                var department = await Api.UpsertHrmDepartmentAsync(new HrmDepartmentRecord { Id = id, TenantId = tenantId, DepartmentCode = _form.Code.Trim(), Name = _form.Name.Trim(), ParentDepartmentId = ParseGuid(_form.ParentDepartmentIdText), ManagerId = ParseGuid(_form.ManagerIdText), CostCenterCode = _form.CostCenterCode.Trim(), Location = _form.Location.Trim(), Status = BlankDefault(_form.Status, "Active"), Description = _form.Extra ?? "", UpdatedAt = now });
                return department?.Id ?? id;
            case "positions":
                var position = await Api.UpsertHrmPositionAsync(new HrmPositionRecord { Id = id, TenantId = tenantId, PositionCode = _form.Code.Trim(), Name = _form.Name.Trim(), DepartmentId = ParseGuid(_form.DepartmentIdText), Level = _form.JobLevel.Trim(), JobGrade = _form.JobGrade.Trim(), MinSalary = _form.MinSalary, MaxSalary = _form.Amount, Status = BlankDefault(_form.Status, "Active"), Description = _form.Extra ?? "", UpdatedAt = now });
                return position?.Id ?? id;
            case "contracts":
                var contract = await Api.UpsertHrmContractAsync(new HrmContractRecord { Id = id, TenantId = tenantId, ContractNo = _form.Code.Trim(), ContractType = _form.Name.Trim(), Status = BlankDefault(_form.Status, "Draft"), BaseSalary = _form.Amount, Currency = "VND", WorkingLocation = _form.Extra ?? "", EffectiveFrom = ToDateOnly(_form.StartDate), EffectiveTo = ToDateOnly(_form.EndDate), UpdatedAt = now });
                return contract?.Id ?? id;
            default:
                var requisition = await Api.UpsertHrmRequisitionAsync(new HrmRequisitionRecord { Id = id, TenantId = tenantId, RequisitionNo = _form.Code.Trim(), Title = _form.Name.Trim(), DepartmentId = ParseGuid(_form.DepartmentIdText), PositionId = ParseGuid(_form.PositionIdText), Status = BlankDefault(_form.Status, "Open"), SalaryMax = _form.Amount, WorkLocation = _form.Extra ?? "", UpdatedAt = now });
                return requisition?.Id ?? id;
        }
    }

    private string DeleteEndpoint() => Definition.Kind switch
    {
        "employees" or "profiles" or "dashboard" => "employees",
        "departments" => "departments",
        "positions" => "positions",
        "contracts" => "contracts",
        _ => "requisitions"
    };

    private string DefaultStatus() => Definition.Kind switch
    {
        "departments" or "positions" => "Active",
        "recruitment" => "Open",
        _ => "Draft"
    };

    private static string BlankDefault(string? value, string fallback) => string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    private static DateOnly? ToDateOnly(DateTime? value) => value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
    private static DateTime? ToDateTime(DateOnly? value) => value.HasValue ? value.Value.ToDateTime(TimeOnly.MinValue) : null;
    private static Guid? ParseGuid(string? value) => Guid.TryParse(value, out var id) ? id : null;
    private string DepartmentName(Guid? id) => id.HasValue ? _departments.FirstOrDefault(x => x.Id == id.Value)?.Name ?? "-" : "-";
    private string PositionName(Guid? id) => id.HasValue ? _positions.FirstOrDefault(x => x.Id == id.Value)?.Name ?? "-" : "-";
    private string ManagerName(Guid? id) => id.HasValue ? _employees.FirstOrDefault(x => x.Id == id.Value)?.FullName ?? "-" : "-";

    private HrmDefinition ResolveDefinition()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').ToLowerInvariant();
        return path switch
        {
            "hrm/employees" => new("employees", "Nhân viên", "Danh sách nhân viên đầy đủ hồ sơ, trạng thái lao động, phòng ban, chức vụ, lương cơ bản.", NexusPermissions.Hrm.Employees.View),
            "hrm/departments" => new("departments", "Phòng ban", "Cơ cấu phòng ban, quản lý, cost center và địa điểm làm việc.", NexusPermissions.Hrm.Departments.View),
            "hrm/positions" => new("positions", "Chức vụ", "Danh mục chức vụ, level, job grade và dải lương.", NexusPermissions.Hrm.Positions.View),
            "hrm/contracts" => new("contracts", "Hợp đồng lao động", "Hợp đồng, hiệu lực, lương, phụ cấp, file ký và trạng thái duyệt.", NexusPermissions.Hrm.Contracts.View),
            "hrm/profiles" => new("profiles", "Hồ sơ nhân sự", "Hồ sơ cá nhân, liên hệ, giấy tờ, bảo hiểm, ngân hàng và file đính kèm.", NexusPermissions.Hrm.Employees.View),
            "hrm/recruitment" => new("recruitment", "Tuyển dụng", "Requisition, candidate, application, interview và offer.", NexusPermissions.Hrm.Recruitment.View),
            "hrm/onboarding" => new("onboarding", "Onboarding/Offboarding", "Checklist nhận việc, nghỉ việc và các bước bàn giao.", NexusPermissions.Hrm.Onboarding.View),
            _ => new("dashboard", "Dashboard nhân sự", "Tổng quan nhanh hồ sơ nhân sự và các trạng thái chính.", NexusPermissions.Hrm.Dashboard.View)
        };
    }

    private static string DateText(DateOnly? value) => value?.ToString("dd/MM/yyyy") ?? "-";
    private static string DateTimeText(DateTimeOffset? value) => value?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-";
    private static string FormatAmount(decimal amount, string currency) => amount <= 0 ? "-" : string.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:N0} {1}", amount, currency);
    private static string StatusText(string status) => status switch
    {
        "Active" => "Hoạt động",
        "Draft" => "Nháp",
        "Probation" => "Thử việc",
        "Official" => "Chính thức",
        "Outsource" => "Outsource",
        "PartTime" => "Part-time",
        "Suspended" => "Tạm ngưng",
        "Signed" => "Đã ký",
        "Completed" => "Đã hoàn thành",
        "Accepted" => "Đã nhận",
        "Resigned" => "Nghỉ việc",
        "Open" => "Đang mở",
        "Won" => "Thắng",
        _ => string.IsNullOrWhiteSpace(status) ? "-" : status
    };

    private static string StatusCss(string status) => status switch
    {
        "Active" or "Official" or "Signed" or "Accepted" or "Won" or "Completed" => "app-status-badge app-status-active",
        "Draft" or "Open" or "Probation" or "Outsource" or "PartTime" or "Suspended" => "app-status-badge app-status-pending",
        "Resigned" or "Rejected" or "Terminated" => "app-status-badge app-status-danger",
        _ => "app-status-badge app-status-muted"
    };

    private Task ShowErrorAsync(Exception ex) =>
        SwalService.Show(new SwalOption { Category = SwalCategory.Error, Title = "Đã xảy ra lỗi", Content = ex.Message });

    private sealed record HrmDefinition(string Kind, string Title, string Description, string ViewPermission);

    private sealed class OperationRow
    {
        public OperationRow()
        {
            Code = string.Empty;
            Name = string.Empty;
            Status = string.Empty;
            Currency = "VND";
            Extra = string.Empty;
            Kind = string.Empty;
        }

        public OperationRow(Guid id, string code, string name, string status, decimal amount, string currency, string extra, DateTimeOffset updatedAt, string kind = "")
        {
            Id = id;
            Code = code;
            Name = name;
            Status = status;
            Amount = amount;
            Currency = currency;
            Extra = extra;
            UpdatedAt = updatedAt;
            Kind = kind;
        }

        public Guid Id { get; set; }
        public string Code { get; set; }
        public string Name { get; set; }
        public string Status { get; set; }
        public decimal Amount { get; set; }
        public string Currency { get; set; }
        public string Extra { get; set; }
        public DateTimeOffset UpdatedAt { get; set; }
        public string Kind { get; set; }
    }

