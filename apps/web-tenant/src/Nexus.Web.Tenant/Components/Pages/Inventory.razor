@page "/inventory"
@attribute [TabItemOption(Text = "Tồn kho", Icon = "fa-solid fa-boxes-stacked")]
@inject TenantPortalApiClient Api
@inject TenantSessionService Session
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Tồn kho</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">Kho</p>
            <h1>Tồn kho</h1>
            <p>Theo dõi số lượng hiện có, đã giữ và khả dụng theo kho/mã hàng.</p>
        </div>
    </header>

    @if (!Session.HasModule("INVENTORY"))
    {
        <div class="app-alert">Tenant này chưa được bật module Kho.</div>
    }
    else if (!Session.IsGranted(NexusPermissions.Inventory.Stock.View))
    {
        <div class="app-alert">Bạn không có quyền xem tồn kho.</div>
    }
    else
    {
        <Card HeaderText="Số dư tồn kho" IsShadow="true">
            <BodyTemplate>
                <Table @ref="_table" TItem="StockBalanceRecord" OnQueryAsync="OnQueryAsync"
                       IsPagination="true" PageItemsSource="@PageItems" IsStriped="true" IsBordered="true"
                       ShowToolbar="true" ShowDefaultButtons="false" ShowExtendButtons="false"
                       ShowSearch="true" ShowSearchText="true" ShowRefresh="true" ShowAdvancedSearch="false">
                    <TableToolbarTemplate>
                        @if (Session.IsGranted(NexusPermissions.Inventory.Stock.Import))
                        {
                            <TableToolbarButton TItem="StockBalanceRecord" Color="Color.Primary" Icon="fa-solid fa-plus"
                                                Text="Thêm mới" OnClickCallback="ShowImportAsync" />
                        }
                    </TableToolbarTemplate>
                    <TableColumns>
                        <TableColumn @bind-Field="@context.WarehouseCode" Text="Kho" Sortable="true" Searchable="true" />
                        <TableColumn @bind-Field="@context.ProductCode" Text="Mã hàng" Sortable="true" Searchable="true">
                            <Template Context="v">
                                <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => FillImportFromBalance(v.Row))">@v.Row.ProductCode</button>
                            </Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.ProductName" Text="Tên hàng" Searchable="true" />
                        <TableColumn @bind-Field="@context.OnHandQuantity" Text="Tồn hiện có" Sortable="true">
                            <Template Context="v">@v.Row.OnHandQuantity.ToString("N2")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.ReservedQuantity" Text="Đã giữ">
                            <Template Context="v">@v.Row.ReservedQuantity.ToString("N2")</Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.AvailableQuantity" Text="Khả dụng" Sortable="true">
                            <Template Context="v"><span class="@AvailableCss(v.Row.AvailableQuantity)">@v.Row.AvailableQuantity.ToString("N2")</span></Template>
                        </TableColumn>
                        <TableColumn @bind-Field="@context.UpdatedAt" Text="Cập nhật" Sortable="true">
                            <Template Context="v">@v.Row.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</Template>
                        </TableColumn>
                    </TableColumns>
                </Table>
            </BodyTemplate>
        </Card>
    }
</section>

<Modal @ref="_importModal" IsBackdrop="true">
    <ModalDialog Title="Nhập kho nhanh" Size="Size.Large" ShowCloseButton="true">
        <BodyTemplate>
            <div class="app-form-grid">
                <WarehouseLookupSelect Label="Kho" Required="true" @bind-Value="_warehouseCode" />
                <ProductLookupSelect Label="Mã hàng" Required="true" @bind-Value="_productCode" OnProductSelected="OnImportProductSelected" />
                <AppFormField Label="Tên hàng" Required="true">
                    <BootstrapInput @bind-Value="_productName" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Số lượng" Required="true">
                    <BootstrapInputNumber @bind-Value="_quantity" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Số chứng từ">
                    <BootstrapInput @bind-Value="_sourceNo" ShowLabel="false" />
                </AppFormField>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseImportAsync" />
            <Button Text="Nhập kho" Color="Color.Primary" Icon="fa-solid fa-plus" IsAsync="true" OnClick="ImportAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

@code {
    private static readonly int[] PageItems = [10, 20, 50];
    private Table<StockBalanceRecord>? _table;
    private Modal? _importModal;
    private string _warehouseCode = "MAIN";
    private string _productCode = "";
    private string _productName = "";
    private string _sourceNo = "Opening balance";
    private decimal _quantity = 100;

    private async Task<QueryData<StockBalanceRecord>> OnQueryAsync(QueryPageOptions options)
    {
        if (Session.TenantId is not Guid tenantId || !Session.HasModule("INVENTORY") || !Session.IsGranted(NexusPermissions.Inventory.Stock.View))
        {
            return new QueryData<StockBalanceRecord> { Items = [], TotalCount = 0 };
        }

        try
        {
            var all = (await Api.GetStockBalancesAsync(tenantId, options.SearchText))?.ToList() ?? [];
            var items = all.Skip((options.PageIndex - 1) * options.PageItems).Take(options.PageItems).ToList();
            return new QueryData<StockBalanceRecord>
            {
                Items = items,
                TotalCount = all.Count,
                IsFiltered = !string.IsNullOrEmpty(options.SearchText),
                IsSearch = !string.IsNullOrEmpty(options.SearchText)
            };
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            return new QueryData<StockBalanceRecord> { Items = [], TotalCount = 0 };
        }
    }

    private Task ShowImportAsync(IEnumerable<StockBalanceRecord> _)
    {
        _warehouseCode = "MAIN";
        _productCode = "";
        _productName = "";
        _sourceNo = "Opening balance";
        _quantity = 100;
        return _importModal!.Show();
    }

    private Task CloseImportAsync() => _importModal!.Close();

    private async Task ImportAsync()
    {
        if (Session.TenantId is not Guid tenantId)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_warehouseCode) || string.IsNullOrWhiteSpace(_productCode) || string.IsNullOrWhiteSpace(_productName) || _quantity <= 0)
        {
            await ShowErrorAsync(new InvalidOperationException("Vui lòng nhập kho, mã hàng, tên hàng và số lượng hợp lệ."));
            return;
        }

        try
        {
            await Api.ImportStockAsync(new ImportStockRequest(tenantId, _warehouseCode, _productCode, _productName, _quantity, "MANUAL", null, _sourceNo));
            await ToastService.Success("Thành công", "Đã nhập kho.");
            await _importModal!.Close();
            await ReloadTableAsync();
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private async Task FillImportFromBalance(StockBalanceRecord item)
    {
        _warehouseCode = item.WarehouseCode;
        _productCode = item.ProductCode;
        _productName = item.ProductName;
        await _importModal!.Show();
    }

    private void OnImportProductSelected(InventoryProductRecord? product)
    {
        if (product is not null)
        {
            _productName = product.ProductName;
        }
    }

    private async Task ReloadTableAsync()
    {
        if (_table is not null)
        {
            await _table.QueryAsync();
        }
    }

    private static string AvailableCss(decimal value) =>
        value > 0 ? "app-status-badge app-status-active" : "app-status-badge app-status-danger";

    private Task ShowErrorAsync(Exception ex) =>
        SwalService.Show(new SwalOption
        {
            Category = SwalCategory.Error,
            Title = "Đã xảy ra lỗi",
            Content = ex.Message,
            CloseButtonText = "Đóng"
        });
}
