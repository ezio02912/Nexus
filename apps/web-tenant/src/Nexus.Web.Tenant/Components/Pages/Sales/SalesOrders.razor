@page "/sales/orders"
@attribute [TabItemOption(Text = "Đơn hàng", Icon = "fa-solid fa-cart-shopping")]
@inject TenantPortalApiClient Api
@inject CrmApiClient CrmApi
@inject TenantSessionService Session
@inject NavigationManager Navigation

<PageTitle>Đơn hàng - Bán hàng</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">Bán hàng</p>
            <h1>Đơn bán hàng</h1>
            <p>Tạo, duyệt và hoàn tất đơn bán hàng của tenant.</p>
        </div>
        <div class="app-actions">
            <Button Text="Tạo đơn hàng" Color="Color.Primary" Icon="fa-solid fa-plus" OnClick="ShowCreateDialogAsync" />
            <Button Text="Tải lại" Color="Color.Secondary" OnClick="LoadAsync" />
        </div>
    </header>

    @if (!Session.HasModule("SALES"))
    {
        <div class="app-alert">Tenant này chưa được bật module Bán hàng.</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="@messageCss">@message</div>
        }

            <section class="app-card app-card-wide">
                <h2>Danh sách đơn hàng</h2>
                <div class="app-list-toolbar">
                    <BootstrapInput @bind-Value="searchText" ShowLabel="false" PlaceHolder="Tìm số đơn, nguồn, trạng thái, mã hàng..." />
                    <Button Text="Tìm" Color="Color.Primary" IsAsync="true" OnClick="LoadAsync" />
                    <Button Text="Xoá lọc" Color="Color.Secondary" IsAsync="true" OnClick="ClearSearchAsync" />
                </div>
                @if (isLoading)
                {
                    <div class="app-loading">Đang tải đơn hàng...</div>
                }
                else if (orders.Count == 0)
                {
                    <div class="app-empty-state">Chưa có đơn bán hàng.</div>
                }
                else
                {
                    <table class="app-table">
                        <thead><tr><th>Số đơn</th><th>Nguồn</th><th>Khách hàng</th><th>Trạng thái</th><th>Giữ hàng</th><th>Giao hàng</th><th>Tổng tiền</th><th>Dòng hàng</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td>
                                        <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => OpenOrder(order.Id))">
                                            @order.OrderNo
                                        </button>
                                    </td>
                                    <td>
                                        @if (order.SourceId.HasValue && !string.IsNullOrWhiteSpace(order.SourceType))
                                        {
                                            <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => OpenSource(order))">
                                                @(order.SourceNo ?? SourceTypeText(order.SourceType))
                                            </button>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td>@CustomerText(order.CustomerId)</td>
                                    <td><span class="@StatusCss(order.Status)">@order.Status</span></td>
                                    <td><span class="@ReservationStatusCss(order.InventoryReservationStatus)">@ReservationStatusText(order.InventoryReservationStatus)</span></td>
                                    <td><span class="@DeliveryStatusCss(order.DeliveryStatus)">@DeliveryStatusText(order.DeliveryStatus)</span></td>
                                    <td>
                                        <div>@order.TotalAmount.ToString("N2")</div>
                                        <small class="text-muted">Thuế @order.TaxAmount.ToString("N0") / CK @order.DiscountAmount.ToString("N0")</small>
                                    </td>
                                    <td>@LinesText(order)</td>
                                    <td>
                                        <div class="app-actions">
                                            <Button Text="Chi tiết" Size="Size.ExtraSmall" Color="Color.Secondary" OnClick="@(() => OpenOrder(order.Id))" />
                                            <Button Text="Duyệt" Size="Size.ExtraSmall" Color="Color.Success" IsDisabled="@(order.Status != "Draft")" OnClick="@(() => ApproveAsync(order.Id))" />
                                            <Button Text="Đã giao" Size="Size.ExtraSmall" Color="Color.Info" IsDisabled="@(order.Status == "Draft" || order.DeliveryStatus == "Delivered")" OnClick="@(() => DeliverAsync(order.Id))" />
                                            <Button Text="Hoàn tất" Size="Size.ExtraSmall" Color="Color.Primary" IsDisabled="@(order.Status != "Approved")" OnClick="@(() => CompleteAsync(order.Id))" />
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
    }
</section>

<Modal @ref="createModal" IsBackdrop="true">
    <ModalDialog Title="Tạo đơn bán hàng" Size="Size.Large" ShowCloseButton="false">
        <BodyTemplate>
            @if (!string.IsNullOrWhiteSpace(sourceNo))
            {
                <div class="app-alert app-alert-compact">Đang tạo đơn hàng từ @sourceTypeText: @sourceNo</div>
            }
            <div class="app-form-grid">
                <CustomerLookupSelect Label="Khách hàng" Required="true" @bind-Value="customerIdText" />
                <AppFormField Label="Số đơn" Required="true">
                    <BootstrapInput @bind-Value="orderNo" ShowLabel="false" />
                </AppFormField>
                <WarehouseLookupSelect Label="Kho" @bind-Value="warehouseCode" />
                <ProductLookupSelect Label="Mã hàng" @bind-Value="productCode" OnProductSelected="OnProductSelected" />
                <AppFormField Label="Mô tả">
                    <BootstrapInput @bind-Value="description" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Số lượng">
                    <BootstrapInputNumber @bind-Value="quantity" ShowLabel="false" />
                </AppFormField>
                <AppMoneyInput Label="Đơn giá" @bind-Value="unitPrice" DecimalPlaces="0" />
                <AppFormField Label="Chiết khấu %">
                    <BootstrapInputNumber @bind-Value="discountPercent" ShowLabel="false" />
                </AppFormField>
                <AppFormField Label="Thuế %">
                    <BootstrapInputNumber @bind-Value="taxPercent" ShowLabel="false" />
                </AppFormField>
            </div>
            <div class="app-detail-grid mt-3">
                <div>
                    <span class="app-detail-label">Tồn khả dụng (@warehouseCode/@productCode)</span>
                    <span class="@(CurrentAvailable >= quantity ? "app-status-badge app-status-active" : "app-status-badge app-status-danger")">@CurrentAvailable.ToString("N2")</span>
                </div>
                <div><span class="app-detail-label">Tạm tính</span><span>@LineSubtotal.ToString("N0")</span></div>
                <div><span class="app-detail-label">Chiết khấu</span><span>@LineDiscountAmount.ToString("N0")</span></div>
                <div><span class="app-detail-label">Thuế</span><span>@LineTaxAmount.ToString("N0")</span></div>
                <div><span class="app-detail-label">Thành tiền</span><span>@LineTotal.ToString("N0")</span></div>
            </div>
            <div class="app-actions mt-3">
                <Button Text="Thêm dòng" Color="Color.Secondary" OnClick="AddLine" />
            </div>
            @if (draftLines.Count > 0)
            {
                <table class="app-table mt-3">
                    <thead><tr><th>Kho</th><th>Mã hàng</th><th>Số lượng</th><th>Đơn giá</th><th>CK</th><th>Thuế</th><th>Thành tiền</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var line in draftLines)
                        {
                            <tr>
                                <td>@line.WarehouseCode</td>
                                <td>@line.ProductCode</td>
                                <td>@line.Quantity.ToString("N2")</td>
                                <td>@line.UnitPrice.ToString("N0")</td>
                                <td>@line.DiscountAmount.ToString("N0")</td>
                                <td>@line.TaxAmount.ToString("N0")</td>
                                <td>@line.LineAmount.ToString("N0")</td>
                                <td><Button Text="Xoá" Size="Size.ExtraSmall" Color="Color.Danger" OnClick="@(() => RemoveLine(line.Id))" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </BodyTemplate>
        <FooterTemplate>
            <Button Text="Huỷ" Color="Color.Secondary" OnClick="CloseCreateDialogAsync" />
            <Button Text="Tạo đơn hàng" Color="Color.Primary" IsAsync="true" OnClick="CreateAsync" />
        </FooterTemplate>
    </ModalDialog>
</Modal>

@code {
    private List<SalesOrderRecord> orders = [];
    private List<CustomerDto> customers = [];
    private List<InventoryProductRecord> products = [];
    private List<WarehouseRecord> warehouses = [];
    private List<StockBalanceRecord> balances = [];
    private List<SalesOrderLineDraftModel> draftLines = [];
    private Modal? createModal;
    private bool isLoading;
    private string customerIdText = "";
    private string orderNo = "SO-0001";
    private string warehouseCode = "MAIN";
    private string productCode = "SKU-001";
    private string description = "Hàng mẫu";
    private string? searchText;
    private decimal quantity = 1;
    private decimal unitPrice = 100;
    private decimal discountPercent;
    private decimal taxPercent;
    private string message = "";
    private string messageCss = "app-alert";
    private string sourceType = "";
    private Guid? sourceId;
    private string sourceNo = "";
    private bool prefillApplied;
    private decimal LineSubtotal => quantity * unitPrice;
    private decimal LineDiscountAmount => decimal.Round(LineSubtotal * Math.Clamp(discountPercent, 0m, 100m) / 100m, 2, MidpointRounding.AwayFromZero);
    private decimal LineTaxAmount => decimal.Round((LineSubtotal - LineDiscountAmount) * Math.Max(0m, taxPercent) / 100m, 2, MidpointRounding.AwayFromZero);
    private decimal LineTotal => LineSubtotal - LineDiscountAmount + LineTaxAmount;
    private decimal DraftTotal => draftLines.Sum(x => x.LineAmount);
    private string sourceTypeText => sourceType switch
    {
        "quotation" => "báo giá",
        "contract" => "hợp đồng",
        _ => "chứng từ"
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private Task ShowCreateDialogAsync() => createModal!.Show();
    private Task CloseCreateDialogAsync() => createModal!.Close();

    private async Task LoadAsync()
    {
        if (Session.TenantId is not Guid tenantId)
        {
            return;
        }

        isLoading = true;
        orders = (await Api.GetSalesOrdersAsync(tenantId, searchText))?.Items.ToList() ?? [];
        customers = (await CrmApi.GetCustomersAsync(new CustomerListQuery { MaxResultCount = 500 }))?.Items.ToList() ?? [];
        products = await LoadProductsAsync(tenantId);
        warehouses = await LoadWarehousesAsync(tenantId);
        balances = await LoadBalancesAsync(tenantId);
        ApplyPrefillFromQuery();
        isLoading = false;
    }

    private async Task<List<StockBalanceRecord>> LoadBalancesAsync(Guid tenantId)
    {
        if (!Session.HasModule("INVENTORY") || !Session.IsGranted(NexusPermissions.Inventory.Stock.View))
        {
            return [];
        }

        try
        {
            return (await Api.GetStockBalancesAsync(tenantId))?.ToList() ?? [];
        }
        catch
        {
            return [];
        }
    }

    // Available quantity in the selected warehouse for a product, minus what is already
    // staged in the current draft lines for the same warehouse + product.
    private decimal AvailableFor(string warehouse, string product)
    {
        var normalizedWarehouse = (string.IsNullOrWhiteSpace(warehouse) ? "MAIN" : warehouse).Trim().ToUpperInvariant();
        var normalizedProduct = (product ?? "").Trim().ToUpperInvariant();
        var onHand = balances
            .Where(x => x.WarehouseCode == normalizedWarehouse && x.ProductCode == normalizedProduct)
            .Sum(x => x.AvailableQuantity);
        var staged = draftLines
            .Where(x => x.WarehouseCode == normalizedWarehouse && x.ProductCode == normalizedProduct)
            .Sum(x => x.Quantity);
        return onHand - staged;
    }

    private decimal CurrentAvailable => AvailableFor(warehouseCode, productCode);

    private async Task<List<InventoryProductRecord>> LoadProductsAsync(Guid tenantId)
    {
        if (!Session.HasModule("INVENTORY") || !Session.IsGranted(NexusPermissions.Inventory.Products.View))
        {
            return [];
        }

        try
        {
            return (await Api.GetInventoryProductsAsync(tenantId))?.Where(x => x.IsActive).ToList() ?? [];
        }
        catch
        {
            return [];
        }
    }

    private async Task<List<WarehouseRecord>> LoadWarehousesAsync(Guid tenantId)
    {
        if (!Session.HasModule("INVENTORY") || !Session.IsGranted(NexusPermissions.Inventory.Warehouses.View))
        {
            return [];
        }

        try
        {
            return (await Api.GetWarehousesAsync(tenantId))?.Where(x => x.IsActive).ToList() ?? [];
        }
        catch
        {
            return [];
        }
    }

    private async Task CreateAsync()
    {
        if (Session.TenantId is not Guid tenantId || !Guid.TryParse(customerIdText, out var customerId) || string.IsNullOrWhiteSpace(orderNo))
        {
            ShowError("Vui lòng chọn khách hàng và nhập số đơn.");
            return;
        }

        var lines = draftLines.Count > 0
            ? draftLines.Select(x => new CreateSalesOrderLineRequest(x.WarehouseCode, x.ProductCode, x.Description, x.Quantity, x.UnitPrice, x.DiscountPercent, x.TaxPercent)).ToArray()
            : new[] { CurrentLineRequest() };

        if (HasStockData)
        {
            // Aggregate requested quantity per warehouse + product and compare to on-hand availability.
            var shortage = lines
                .GroupBy(x => (Warehouse: (string.IsNullOrWhiteSpace(x.WarehouseCode) ? "MAIN" : x.WarehouseCode).Trim().ToUpperInvariant(),
                               Product: x.ProductCode.Trim().ToUpperInvariant()))
                .Select(g => new
                {
                    g.Key.Warehouse,
                    g.Key.Product,
                    Requested = g.Sum(x => x.Quantity),
                    Available = balances.Where(b => b.WarehouseCode == g.Key.Warehouse && b.ProductCode == g.Key.Product).Sum(b => b.AvailableQuantity)
                })
                .FirstOrDefault(x => x.Requested > x.Available);

            if (shortage is not null)
            {
                ShowError($"Không đủ tồn kho cho {shortage.Warehouse}/{shortage.Product}. Khả dụng {shortage.Available:N2}, cần {shortage.Requested:N2}.");
                return;
            }
        }

        await Api.CreateSalesOrderAsync(new CreateSalesOrderRequest(tenantId, customerId, orderNo, sourceType, sourceId, sourceNo, lines));
        ShowSuccess("Đã tạo đơn bán hàng.");
        draftLines.Clear();
        sourceType = "";
        sourceId = null;
        sourceNo = "";
        await createModal!.Close();
        await LoadAsync();
    }

    private void ApplyPrefillFromQuery()
    {
        if (prefillApplied)
        {
            return;
        }

        var query = ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        if (query.Count == 0)
        {
            return;
        }

        prefillApplied = true;

        if (query.TryGetValue("customerId", out var customerId) && Guid.TryParse(customerId, out _))
        {
            customerIdText = customerId;
        }

        if (query.TryGetValue("sourceType", out var sourceTypeValue))
        {
            sourceType = sourceTypeValue;
        }

        if (query.TryGetValue("sourceId", out var sourceIdValue) && Guid.TryParse(sourceIdValue, out var parsedSourceId))
        {
            sourceId = parsedSourceId;
        }

        if (query.TryGetValue("sourceNo", out var sourceNoValue))
        {
            sourceNo = sourceNoValue;
            orderNo = $"SO-{sourceNoValue}".Replace("/", "-").Replace(" ", "-").ToUpperInvariant();
        }

        if (query.TryGetValue("productCode", out var productCodeValue))
        {
            productCode = productCodeValue;
        }

        if (query.TryGetValue("warehouseCode", out var warehouseValue))
        {
            warehouseCode = warehouseValue;
        }

        if (query.TryGetValue("description", out var descriptionValue))
        {
            description = descriptionValue;
        }

        if (query.TryGetValue("quantity", out var quantityValue) && decimal.TryParse(quantityValue, out var parsedQuantity))
        {
            quantity = parsedQuantity;
        }

        if (query.TryGetValue("unitPrice", out var unitPriceValue) && decimal.TryParse(unitPriceValue, out var parsedUnitPrice))
        {
            unitPrice = parsedUnitPrice;
        }

        if (query.TryGetValue("taxPercent", out var taxValue) && decimal.TryParse(taxValue, out var parsedTax))
        {
            taxPercent = parsedTax;
        }

        if (query.TryGetValue("discountPercent", out var discountValue) && decimal.TryParse(discountValue, out var parsedDiscount))
        {
            discountPercent = parsedDiscount;
        }
    }

    private void SelectProduct(InventoryProductRecord product)
    {
        productCode = product.ProductCode;
        description = product.ProductName;
        unitPrice = product.Price;
        taxPercent = product.TaxPercent;
    }

    // Auto-fill from the product lookup; ProductLookupSelect already updates productCode.
    private void OnProductSelected(InventoryProductRecord? product)
    {
        if (product is null)
        {
            return;
        }

        description = product.ProductName;
        unitPrice = product.Price;
        taxPercent = product.TaxPercent;
    }

    private void SelectWarehouse(WarehouseRecord warehouse)
    {
        warehouseCode = warehouse.WarehouseCode;
    }

    private void AddLine()
    {
        if (string.IsNullOrWhiteSpace(productCode) || quantity <= 0)
        {
            ShowError("Vui lòng nhập mã hàng và số lượng lớn hơn 0.");
            return;
        }

        if (HasStockData && CurrentAvailable < quantity)
        {
            ShowError($"Không đủ tồn kho cho {warehouseCode}/{productCode}. Khả dụng {CurrentAvailable:N2}, cần {quantity:N2}.");
            return;
        }

        draftLines.Add(SalesOrderLineDraftModel.FromRequest(CurrentLineRequest()));
        ShowSuccess($"Đã thêm dòng hàng. Tổng tạm tạo: {DraftTotal.ToString("N0")}");
    }

    // Only enforce the client-side block when we actually loaded stock data for this tenant.
    private bool HasStockData => balances.Count > 0;

    private void RemoveLine(Guid id)
    {
        draftLines.RemoveAll(x => x.Id == id);
    }

    private CreateSalesOrderLineRequest CurrentLineRequest()
    {
        return new CreateSalesOrderLineRequest(warehouseCode, productCode, description, quantity, unitPrice, discountPercent, taxPercent);
    }

    private static Dictionary<string, string> ParseQuery(string query)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(query))
        {
            return result;
        }

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var pair = part.Split('=', 2);
            if (pair.Length == 2)
            {
                result[Uri.UnescapeDataString(pair[0])] = Uri.UnescapeDataString(pair[1].Replace("+", " "));
            }
        }

        return result;
    }

    private async Task ApproveAsync(Guid id)
    {
        await Api.ApproveSalesOrderAsync(id);
        ShowSuccess("Đã duyệt đơn bán hàng.");
        await LoadAsync();
    }

    private async Task CompleteAsync(Guid id)
    {
        await Api.CompleteSalesOrderAsync(id);
        ShowSuccess("Đã hoàn tất đơn bán hàng.");
        await LoadAsync();
    }

    private async Task DeliverAsync(Guid id)
    {
        await Api.DeliverSalesOrderAsync(id);
        ShowSuccess("Đã cập nhật trạng thái giao hàng.");
        await LoadAsync();
    }

    private async Task ClearSearchAsync()
    {
        searchText = null;
        await LoadAsync();
    }

    private static string LinesText(SalesOrderRecord order)
    {
        if (order.Lines is null || order.Lines.Count == 0)
        {
            return "-";
        }

        return string.Join(", ", order.Lines.Select(x => $"{x.WarehouseCode}/{x.ProductCode} x{x.Quantity:N0}"));
    }

    private static string CustomerOption(CustomerDto customer) => $"{customer.Code} - {customer.Name}";

    private void OpenSource(SalesOrderRecord order)
    {
        if (!order.SourceId.HasValue || string.IsNullOrWhiteSpace(order.SourceType))
        {
            return;
        }

        var route = order.SourceType.Equals("contract", StringComparison.OrdinalIgnoreCase)
            ? $"crm/contracts/{order.SourceId.Value}"
            : order.SourceType.Equals("quotation", StringComparison.OrdinalIgnoreCase)
                ? $"crm/quotations/{order.SourceId.Value}"
                : "";

        if (!string.IsNullOrWhiteSpace(route))
        {
            Navigation.NavigateTo(route);
        }
    }

    private void OpenOrder(Guid id) => Navigation.NavigateTo($"sales/orders/{id}");

    private static string SourceTypeText(string? value) => value switch
    {
        "quotation" => "Báo giá",
        "contract" => "Hợp đồng",
        _ => "Nguồn"
    };

    private string CustomerText(Guid customerId)
    {
        var customer = customers.FirstOrDefault(x => x.Id == customerId);
        return customer is null ? "Không xác định" : CustomerOption(customer);
    }

    private static string StatusCss(string status) => status switch
    {
        "Approved" => "app-status-badge app-status-active",
        "Completed" => "app-status-badge app-status-active",
        _ => "app-status-badge app-status-muted"
    };

    private static string DeliveryStatusText(string? status) => status switch
    {
        "Delivered" => "Đã giao",
        "Ready" => "Sẵn sàng giao",
        _ => "Chờ giao"
    };

    private static string ReservationStatusText(string? status) => status switch
    {
        "Reserved" => "Đã giữ",
        _ => "Chờ giữ"
    };

    private static string DeliveryStatusCss(string? status) => status switch
    {
        "Delivered" => "app-status-badge app-status-active",
        "Ready" => "app-status-badge app-status-pending",
        _ => "app-status-badge app-status-muted"
    };

    private static string ReservationStatusCss(string? status) => status switch
    {
        "Reserved" => "app-status-badge app-status-active",
        _ => "app-status-badge app-status-muted"
    };

    private void ShowSuccess(string text)
    {
        message = text;
        messageCss = "app-alert";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCss = "app-alert app-alert-danger";
    }

    private sealed record SalesOrderLineDraftModel(
        Guid Id,
        string WarehouseCode,
        string ProductCode,
        string Description,
        decimal Quantity,
        decimal UnitPrice,
        decimal DiscountPercent,
        decimal DiscountAmount,
        decimal TaxPercent,
        decimal TaxAmount,
        decimal Subtotal,
        decimal LineAmount)
    {
        public static SalesOrderLineDraftModel FromRequest(CreateSalesOrderLineRequest request)
        {
            var subtotal = request.Quantity * request.UnitPrice;
            var discountPercent = Math.Clamp(request.DiscountPercent, 0m, 100m);
            var discountAmount = decimal.Round(subtotal * discountPercent / 100m, 2, MidpointRounding.AwayFromZero);
            var taxPercent = Math.Max(0m, request.TaxPercent);
            var taxAmount = decimal.Round((subtotal - discountAmount) * taxPercent / 100m, 2, MidpointRounding.AwayFromZero);
            return new SalesOrderLineDraftModel(
                Guid.NewGuid(),
                string.IsNullOrWhiteSpace(request.WarehouseCode) ? "MAIN" : request.WarehouseCode.Trim().ToUpperInvariant(),
                request.ProductCode.Trim().ToUpperInvariant(),
                request.Description.Trim(),
                request.Quantity,
                request.UnitPrice,
                discountPercent,
                discountAmount,
                taxPercent,
                taxAmount,
                subtotal,
                subtotal - discountAmount + taxAmount);
        }
    }
}
