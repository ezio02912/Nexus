@page "/sales/orders"
@attribute [TabItemOption(Text = "Đơn hàng", Icon = "fa-solid fa-cart-shopping")]
@inject TenantPortalApiClient Api
@inject CrmApiClient CrmApi
@inject TenantSessionService Session
@inject NavigationManager Navigation

<PageTitle>Đơn hàng - Bán hàng</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">Bán hàng</p>
            <h1>Đơn bán hàng</h1>
            <p>Tạo, duyệt và hoàn tất đơn bán hàng của tenant.</p>
        </div>
        <Button Text="Tải lại" Color="Color.Secondary" OnClick="LoadAsync" />
    </header>

    @if (!Session.HasModule("SALES"))
    {
        <div class="app-alert">Tenant này chưa được bật module Bán hàng.</div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="@messageCss">@message</div>
        }

        <div class="tenant-work-grid">
            <section class="app-card">
                <h2>Tạo đơn hàng</h2>
                @if (!string.IsNullOrWhiteSpace(sourceNo))
                {
                    <div class="app-alert app-alert-compact">Đang tạo đơn hàng từ @sourceTypeText: @sourceNo</div>
                }
                <div class="app-form-grid">
                    <CustomerLookupSelect Label="Khách hàng" Required="true" @bind-Value="customerIdText" />
                    <AppFormField Label="Số đơn" Required="true">
                        <BootstrapInput @bind-Value="orderNo" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Mã hàng">
                        <BootstrapInput @bind-Value="productCode" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Mô tả">
                        <BootstrapInput @bind-Value="description" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Số lượng">
                        <BootstrapInputNumber @bind-Value="quantity" ShowLabel="false" />
                    </AppFormField>
                    <AppMoneyInput Label="Đơn giá" @bind-Value="unitPrice" DecimalPlaces="0" />
                </div>
                <Button Text="Tạo đơn hàng" Color="Color.Primary" OnClick="CreateAsync" />
            </section>

            <section class="app-card app-card-wide">
                <h2>Danh sách đơn hàng</h2>
                <div class="app-list-toolbar">
                    <BootstrapInput @bind-Value="searchText" ShowLabel="false" PlaceHolder="Tìm số đơn, nguồn, trạng thái, mã hàng..." />
                    <Button Text="Tìm" Color="Color.Primary" IsAsync="true" OnClick="LoadAsync" />
                    <Button Text="Xoá lọc" Color="Color.Secondary" IsAsync="true" OnClick="ClearSearchAsync" />
                </div>
                @if (isLoading)
                {
                    <div class="app-loading">Đang tải đơn hàng...</div>
                }
                else if (orders.Count == 0)
                {
                    <div class="app-empty-state">Chưa có đơn bán hàng.</div>
                }
                else
                {
                    <table class="app-table">
                        <thead><tr><th>Số đơn</th><th>Nguồn</th><th>Khách hàng</th><th>Trạng thái</th><th>Tổng tiền</th><th>Dòng hàng</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr>
                                    <td>@order.OrderNo</td>
                                    <td>
                                        @if (order.SourceId.HasValue && !string.IsNullOrWhiteSpace(order.SourceType))
                                        {
                                            <button class="app-table-link app-table-link-code" type="button" @onclick="@(() => OpenSource(order))">
                                                @(order.SourceNo ?? SourceTypeText(order.SourceType))
                                            </button>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td>@CustomerText(order.CustomerId)</td>
                                    <td><span class="@StatusCss(order.Status)">@order.Status</span></td>
                                    <td>@order.TotalAmount.ToString("N2")</td>
                                    <td>@LinesText(order)</td>
                                    <td>
                                        <div class="app-actions">
                                            <Button Text="Duyệt" Size="Size.ExtraSmall" Color="Color.Success" IsDisabled="@(order.Status != "Draft")" OnClick="@(() => ApproveAsync(order.Id))" />
                                            <Button Text="Hoàn tất" Size="Size.ExtraSmall" Color="Color.Primary" IsDisabled="@(order.Status != "Approved")" OnClick="@(() => CompleteAsync(order.Id))" />
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        </div>
    }
</section>

@code {
    private List<SalesOrderRecord> orders = [];
    private List<CustomerDto> customers = [];
    private bool isLoading;
    private string customerIdText = "";
    private string orderNo = "SO-0001";
    private string productCode = "SKU-001";
    private string description = "Hàng mẫu";
    private string? searchText;
    private decimal quantity = 1;
    private decimal unitPrice = 100;
    private string message = "";
    private string messageCss = "app-alert";
    private string sourceType = "";
    private Guid? sourceId;
    private string sourceNo = "";
    private bool prefillApplied;
    private string sourceTypeText => sourceType switch
    {
        "quotation" => "báo giá",
        "contract" => "hợp đồng",
        _ => "chứng từ"
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (Session.TenantId is not Guid tenantId)
        {
            return;
        }

        isLoading = true;
        orders = (await Api.GetSalesOrdersAsync(tenantId, searchText))?.Items.ToList() ?? [];
        customers = (await CrmApi.GetCustomersAsync(new CustomerListQuery { MaxResultCount = 500 }))?.Items.ToList() ?? [];
        ApplyPrefillFromQuery();
        isLoading = false;
    }

    private async Task CreateAsync()
    {
        if (Session.TenantId is not Guid tenantId || !Guid.TryParse(customerIdText, out var customerId) || string.IsNullOrWhiteSpace(orderNo))
        {
            ShowError("Vui lòng chọn khách hàng và nhập số đơn.");
            return;
        }

        var lines = new[] { new CreateSalesOrderLineRequest(productCode, description, quantity, unitPrice) };
        await Api.CreateSalesOrderAsync(new CreateSalesOrderRequest(tenantId, customerId, orderNo, sourceType, sourceId, sourceNo, lines));
        ShowSuccess("Đã tạo đơn bán hàng.");
        sourceType = "";
        sourceId = null;
        sourceNo = "";
        await LoadAsync();
    }

    private void ApplyPrefillFromQuery()
    {
        if (prefillApplied)
        {
            return;
        }

        var query = ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        if (query.Count == 0)
        {
            return;
        }

        prefillApplied = true;

        if (query.TryGetValue("customerId", out var customerId) && Guid.TryParse(customerId, out _))
        {
            customerIdText = customerId;
        }

        if (query.TryGetValue("sourceType", out var sourceTypeValue))
        {
            sourceType = sourceTypeValue;
        }

        if (query.TryGetValue("sourceId", out var sourceIdValue) && Guid.TryParse(sourceIdValue, out var parsedSourceId))
        {
            sourceId = parsedSourceId;
        }

        if (query.TryGetValue("sourceNo", out var sourceNoValue))
        {
            sourceNo = sourceNoValue;
            orderNo = $"SO-{sourceNoValue}".Replace("/", "-").Replace(" ", "-").ToUpperInvariant();
        }

        if (query.TryGetValue("productCode", out var productCodeValue))
        {
            productCode = productCodeValue;
        }

        if (query.TryGetValue("description", out var descriptionValue))
        {
            description = descriptionValue;
        }

        if (query.TryGetValue("quantity", out var quantityValue) && decimal.TryParse(quantityValue, out var parsedQuantity))
        {
            quantity = parsedQuantity;
        }

        if (query.TryGetValue("unitPrice", out var unitPriceValue) && decimal.TryParse(unitPriceValue, out var parsedUnitPrice))
        {
            unitPrice = parsedUnitPrice;
        }
    }

    private static Dictionary<string, string> ParseQuery(string query)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(query))
        {
            return result;
        }

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var pair = part.Split('=', 2);
            if (pair.Length == 2)
            {
                result[Uri.UnescapeDataString(pair[0])] = Uri.UnescapeDataString(pair[1].Replace("+", " "));
            }
        }

        return result;
    }

    private async Task ApproveAsync(Guid id)
    {
        await Api.ApproveSalesOrderAsync(id);
        ShowSuccess("Đã duyệt đơn bán hàng.");
        await LoadAsync();
    }

    private async Task CompleteAsync(Guid id)
    {
        await Api.CompleteSalesOrderAsync(id);
        ShowSuccess("Đã hoàn tất đơn bán hàng.");
        await LoadAsync();
    }

    private async Task ClearSearchAsync()
    {
        searchText = null;
        await LoadAsync();
    }

    private static string LinesText(SalesOrderRecord order)
    {
        if (order.Lines is null || order.Lines.Count == 0)
        {
            return "-";
        }

        return string.Join(", ", order.Lines.Select(x => $"{x.ProductCode} x{x.Quantity:N0}"));
    }

    private static string CustomerOption(CustomerDto customer) => $"{customer.Code} - {customer.Name}";

    private void OpenSource(SalesOrderRecord order)
    {
        if (!order.SourceId.HasValue || string.IsNullOrWhiteSpace(order.SourceType))
        {
            return;
        }

        var route = order.SourceType.Equals("contract", StringComparison.OrdinalIgnoreCase)
            ? $"crm/contracts/{order.SourceId.Value}"
            : order.SourceType.Equals("quotation", StringComparison.OrdinalIgnoreCase)
                ? $"crm/quotations/{order.SourceId.Value}"
                : "";

        if (!string.IsNullOrWhiteSpace(route))
        {
            Navigation.NavigateTo(route);
        }
    }

    private static string SourceTypeText(string? value) => value switch
    {
        "quotation" => "Báo giá",
        "contract" => "Hợp đồng",
        _ => "Nguồn"
    };

    private string CustomerText(Guid customerId)
    {
        var customer = customers.FirstOrDefault(x => x.Id == customerId);
        return customer is null ? "Không xác định" : CustomerOption(customer);
    }

    private static string StatusCss(string status) => status switch
    {
        "Approved" => "app-status-badge app-status-active",
        "Completed" => "app-status-badge app-status-active",
        _ => "app-status-badge app-status-muted"
    };

    private void ShowSuccess(string text)
    {
        message = text;
        messageCss = "app-alert";
    }

    private void ShowError(string text)
    {
        message = text;
        messageCss = "app-alert app-alert-danger";
    }
}
