@page "/settings"
@rendermode InteractiveServer
@inject TenantSessionService Session

<PageTitle>Thiết lập</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">Quản trị tenant</p>
            <h1>Thiết lập</h1>
            <p>Thông tin tenant, phân hệ đã bật và ngữ cảnh workspace hiện tại.</p>
        </div>
    </header>

    @if (!Session.IsAuthenticated)
    {
        <div class="app-alert">Đăng nhập để xem thiết lập tenant.</div>
    }
    else
    {
        <div class="app-grid">
            <section class="app-card">
                <h2>Tenant</h2>
                <table class="app-table">
                    <tbody>
                        <tr><th>Tên</th><td>@Session.Tenant?.Name</td></tr>
                        <tr><th>Mã</th><td>@Session.Tenant?.Code</td></tr>
                        <tr><th>Trạng thái</th><td><span class="app-status-badge app-status-active">@Session.Tenant?.Status</span></td></tr>
                        <tr><th>Người dùng</th><td>@Session.UserName</td></tr>
                    </tbody>
                </table>
            </section>
            <section class="app-card">
                <h2>Phân hệ</h2>
                @if (Session.EnabledModules.Count == 0)
                {
                    <div class="app-empty-state">Tenant này chưa bật phân hệ nào.</div>
                }
                else
                {
                    <div class="tenant-permission-catalog">
                        @foreach (var module in Session.EnabledModules)
                        {
                            <div class="tenant-permission-item">
                                <span class="app-status-badge app-status-active">@module</span>
                                <span>Menu và workspace đang hiển thị cho phân hệ này.</span>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    }
</section>
