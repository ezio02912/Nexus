@page "/tenant-permissions"
@inject TenantPortalApiClient Api
@inject TenantSessionService Session
@inject SwalService SwalService
@inject ToastService ToastService

<PageTitle>Phân quyền tenant</PageTitle>

<section class="app-page">
    <header class="app-page-header">
        <div>
            <p class="app-eyebrow">Quản trị tenant</p>
            <h1>Phân quyền</h1>
            <p>Quản lý quyền theo vai trò trong phạm vi tenant hiện tại.</p>
        </div>
    </header>

    @if (!Session.IsAuthenticated)
    {
        <div class="app-alert">Đăng nhập để quản lý phân quyền tenant.</div>
    }
    else if (!Session.IsGranted(NexusPermissions.TenantAdmin.Permissions.View))
    {
        <div class="app-alert">Bạn không có quyền xem trang phân quyền.</div>
    }
    else
    {
        <div class="tenant-permissions-layout">
            <Card HeaderText="Gán quyền vai trò" IsShadow="true">
                <BodyTemplate>
                    <Select TValue="string" @bind-Value="_roleName" Items="@_roleOptions"
                            DisplayText="Tên vai trò" ShowLabel="true" class="mb-2" />
                    <div class="form-text mb-3">Khóa theo tenant: <code>@ScopedRoleName</code></div>
                    <div class="app-actions app-actions-left">
                        <Button Text="Tải quyền" Color="Color.Secondary" IsAsync="true" OnClick="LoadRoleAsync" IsDisabled="_loadingRole" />
                        @if (Session.IsGranted(NexusPermissions.TenantAdmin.Permissions.Manage))
                        {
                            <Button Text="Lưu quyền" Color="Color.Primary" IsAsync="true" OnClick="SaveAsync" IsDisabled="_loadingRole" />
                        }
                    </div>
                </BodyTemplate>
            </Card>

            <Card HeaderText="Danh mục quyền theo menu / dịch vụ" IsShadow="true">
                <BodyTemplate>
                    <div class="tenant-permission-toolbar">
                        <BootstrapInput @bind-Value="_filter" DisplayText="Lọc quyền" ShowLabel="false"
                                        PlaceHolder="Lọc theo module, menu, dịch vụ hoặc hành động..." />
                    </div>

                    @if (_loading || _loadingRole)
                    {
                        <div class="app-loading py-4">
                            <Spinner Color="Color.Primary" />
                            <span class="app-loading-text">@(_loading ? "Đang tải danh mục quyền..." : "Đang tải quyền vai trò...")</span>
                        </div>
                    }
                    else if (!PermissionAreas.Any())
                    {
                        <div class="text-muted py-3">Không có quyền phù hợp với bộ lọc.</div>
                    }
                    else
                    {
                        @foreach (var area in PermissionAreas)
                        {
                            <section class="tenant-permission-area">
                                <h2>@area.AreaLabel</h2>
                                @foreach (var menu in area.Menus)
                                {
                                    <div class="tenant-permission-group">
                                        <div class="tenant-permission-group-header">
                                            <h3>@menu.MenuLabel</h3>
                                            @if (Session.IsGranted(NexusPermissions.TenantAdmin.Permissions.Manage))
                                            {
                                                <Checkbox TValue="bool"
                                                          DisplayText="Chọn tất cả"
                                                          Value="@IsMenuFullySelected(menu)"
                                                          OnStateChanged="@((state, _) => ToggleMenuAsync(menu, state))" />
                                            }
                                        </div>
                                        <div class="tenant-permission-catalog">
                                            @foreach (var action in menu.Actions)
                                            {
                                                <label class="tenant-permission-item">
                                                    @if (Session.IsGranted(NexusPermissions.TenantAdmin.Permissions.Manage))
                                                    {
                                                        <Checkbox TValue="bool"
                                                                  Value="@_selectedPermissions.Contains(action.Key)"
                                                                  OnStateChanged="@((state, _) => TogglePermissionAsync(action.Key, state))" />
                                                    }
                                                    else
                                                    {
                                                        <input type="checkbox" checked="@_selectedPermissions.Contains(action.Key)" disabled />
                                                    }
                                                    <span>
                                                        <strong>@action.Label</strong>
                                                        <span class="tenant-permission-service">
                                                            Dịch vụ: <code>@TenantPermissionCatalog.GetServiceKey(action.Key)</code>
                                                        </span>
                                                        <code>@action.Key</code>
                                                    </span>
                                                </label>
                                            }
                                        </div>
                                    </div>
                                }
                            </section>
                        }
                    }
                </BodyTemplate>
            </Card>
        </div>
    }
</section>

@code {
    private static readonly List<SelectedItem> _roleOptions =
    [
        new("TenantAdmin", "TenantAdmin"),
        new("User", "User")
    ];

    private List<string> _catalog = [];
    private HashSet<string> _selectedPermissions = new(StringComparer.OrdinalIgnoreCase);
    private string _roleName = "TenantAdmin";
    private string _filter = "";
    private bool _loading = true;
    private bool _loadingRole;

    private string ScopedRoleName => $"{(Session.TenantId?.ToString("N") ?? "NO-TENANT")}:{_roleName}".ToUpperInvariant();

    private IEnumerable<TenantPermissionCatalog.AreaPermissionGroup> PermissionAreas =>
        TenantPermissionCatalog.GetVisibleGroups(_catalog, _filter);

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogAsync();
        await LoadRoleAsync();
    }

    private async Task LoadCatalogAsync()
    {
        _loading = true;
        try
        {
            var remote = (await Api.GetPermissionCatalogAsync())?.ToHashSet(StringComparer.OrdinalIgnoreCase)
                         ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var assignable = NexusPermissions.TenantAssignable
                .Where(x => remote.Count == 0 || remote.Contains(x))
                .OrderBy(x => x)
                .ToList();
            _catalog = assignable.Count > 0
                ? assignable
                : NexusPermissions.TenantAssignable.OrderBy(x => x).ToList();
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
            _catalog = NexusPermissions.TenantAssignable.OrderBy(x => x).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadRoleAsync()
    {
        _loadingRole = true;
        try
        {
            var result = await Api.GetRolePermissionsAsync(ScopedRoleName);
            _selectedPermissions = NexusPermissionLegacy.Expand(result?.Permissions ?? []);
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
        finally
        {
            _loadingRole = false;
            StateHasChanged();
        }
    }

    private async Task SaveAsync()
    {
        if (!Session.IsGranted(NexusPermissions.TenantAdmin.Permissions.Manage))
        {
            return;
        }

        try
        {
            var permissions = _selectedPermissions
                .Where(x => NexusPermissions.TenantAssignable.Contains(x, StringComparer.OrdinalIgnoreCase))
                .OrderBy(x => x)
                .ToArray();
            var result = await Api.UpdateRolePermissionsAsync(ScopedRoleName, new UpdateRolePermissionsRequest(permissions));
            _selectedPermissions = NexusPermissionLegacy.Expand(result?.Permissions ?? []);
            await ToastService.Success("Đã lưu", $"Đã lưu {_selectedPermissions.Count} quyền cho {_roleName}.");
        }
        catch (Exception ex)
        {
            await ShowErrorAsync(ex);
        }
    }

    private bool IsMenuFullySelected(TenantPermissionCatalog.MenuPermissionGroup menu) =>
        menu.Actions.All(x => _selectedPermissions.Contains(x.Key));

    private Task TogglePermissionAsync(string permission, CheckboxState state)
    {
        if (state == CheckboxState.Checked)
        {
            _selectedPermissions.Add(permission);
        }
        else
        {
            _selectedPermissions.Remove(permission);
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ToggleMenuAsync(TenantPermissionCatalog.MenuPermissionGroup menu, CheckboxState state)
    {
        var selectAll = state == CheckboxState.Checked;
        foreach (var action in menu.Actions)
        {
            if (selectAll)
            {
                _selectedPermissions.Add(action.Key);
            }
            else
            {
                _selectedPermissions.Remove(action.Key);
            }
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ShowErrorAsync(Exception ex) => SwalService.Show(new SwalOption
    {
        Category = SwalCategory.Error,
        Title = "Đã xảy ra lỗi",
        Content = ex.Message,
        CloseButtonText = "Đóng"
    });
}
