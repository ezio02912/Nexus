<div class="app-form-field @Class @(HasError ? "app-form-field-invalid" : "")">
    <label class="app-form-label" for="@InputId">
        @Label
        @if (Required)
        {
            <span class="app-form-required" aria-hidden="true">*</span>
        }
    </label>
    @ChildContent
    @if (HasError && !string.IsNullOrWhiteSpace(ErrorText))
    {
        <div class="app-form-error">@ErrorText</div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public bool Required { get; set; }
    [Parameter] public string InputId { get; set; } = Guid.NewGuid().ToString("N");
    [Parameter] public RenderFragment? ChildContent { get; set; }

    // Optional extra CSS class, e.g. "app-form-field-full" to span the whole form grid row.
    [Parameter] public string? Class { get; set; }

    // When true, the field is highlighted (red border) and the error line is shown.
    [Parameter] public bool HasError { get; set; }
    [Parameter] public string? ErrorText { get; set; }
}
