@using System.Globalization
@using Nexus.Web.Tenant.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<AppFormField Label="@Label" Required="@Required" InputId="@_inputId">
    <input @ref="_inputElement"
           id="@_inputId"
           class="form-control app-money-input"
           type="text"
           inputmode="decimal"
           placeholder="@Placeholder"
           disabled="@Disabled"
           value="@_displayValue" />
</AppFormField>

@code {
    private readonly string _inputId = $"money-{Guid.NewGuid():N}";

    [Parameter] public string Label { get; set; } = "";
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public int DecimalPlaces { get; set; }
    [Parameter] public decimal Value { get; set; }
    [Parameter] public EventCallback<decimal> ValueChanged { get; set; }

    private ElementReference _inputElement;
    private IJSObjectReference? _module;
    private DotNetObjectReference<AppMoneyInput>? _dotNetRef;
    private string _displayValue = "";
    private bool _focused;
    private bool _disposed;

    protected override void OnParametersSet()
    {
        // Refresh the display only when the user is not actively typing so the
        // JS-managed caret and partial input are never clobbered by a re-render.
        if (!_focused)
        {
            _displayValue = VnMoney.Format(Value, DecimalPlaces);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/money-input.js");
            await _module.InvokeVoidAsync("init", _inputElement, _dotNetRef, new { decimalPlaces = DecimalPlaces });
        }
    }

    [JSInvokable]
    public Task OnInput(string raw)
    {
        // A late JS callback can arrive after the component was disposed.
        if (_disposed)
        {
            return Task.CompletedTask;
        }

        _focused = true;
        Value = ParseInvariant(raw);
        return ValueChanged.InvokeAsync(Value);
    }

    [JSInvokable]
    public async Task OnBlur(string raw)
    {
        // A late JS callback can arrive after the component was disposed.
        if (_disposed)
        {
            return;
        }

        _focused = false;
        Value = ParseInvariant(raw);
        _displayValue = VnMoney.Format(Value, DecimalPlaces);
        await ValueChanged.InvokeAsync(Value);
        StateHasChanged();
    }

    // The JS layer always sends an invariant numeric string (e.g. "1234.5").
    private static decimal ParseInvariant(string? raw) =>
        decimal.TryParse(raw, NumberStyles.Number, CultureInfo.InvariantCulture, out var value) ? value : 0;

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("dispose", _inputElement);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit already gone; nothing to clean up on the client.
        }

        _dotNetRef?.Dispose();
    }
}
