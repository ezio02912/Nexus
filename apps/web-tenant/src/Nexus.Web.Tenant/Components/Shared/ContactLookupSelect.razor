@inject CrmApiClient CrmApi
@inject ToastService ToastService

<AppFormField Label="@Label" Required="@Required" InputId="@_selectId" HasError="@HasError" ErrorText="@ErrorText">
    @if (!HasCustomer)
    {
        <div class="app-alert app-alert-compact">Chọn khách hàng trước khi chọn liên hệ.</div>
    }
    else
    {
        <div class="customer-lookup">
            <Select TValue="string"
                    @bind-Value="SelectedContactId"
                    ShowLabel="false"
                    ShowSearch="true"
                    IsVirtualize="true"
                    IsPopover="true"
                    PlaceHolder="@PlaceHolder"
                    OnQueryAsync="QueryContactsAsync"
                    DisplayTemplate="RenderSelectedContact">
                <ItemTemplate Context="item">
                    <div class="lookup-item">
                        <strong>@item.Text</strong>
                    </div>
                </ItemTemplate>
            </Select>
            <Button Text="@(_showQuickCreate ? "Ẩn" : "Tạo nhanh")"
                    Icon="fa-solid fa-plus"
                    Color="Color.Light"
                    Size="Size.Small"
                    OnClick="ToggleQuickCreate" />
        </div>

        @if (_showQuickCreate)
        {
            <div class="customer-quick-create">
                <div class="app-form-grid app-form-grid-compact">
                    <AppFormField Label="Họ tên" Required="true">
                        <BootstrapInput @bind-Value="_quick.FullName" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Email">
                        <BootstrapInput @bind-Value="_quick.Email" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Điện thoại">
                        <BootstrapInput @bind-Value="_quick.Phone" ShowLabel="false" />
                    </AppFormField>
                    <AppFormField Label="Chức vụ">
                        <BootstrapInput @bind-Value="_quick.Position" ShowLabel="false" />
                    </AppFormField>
                </div>
                <div class="customer-quick-create-actions">
                    <Button Text="Huỷ" Color="Color.Secondary" Size="Size.Small" OnClick="CancelQuickCreate" />
                    <Button Text="Tạo và chọn" Color="Color.Primary" Size="Size.Small" IsAsync="true" OnClick="CreateContactAsync" />
                </div>
            </div>
        }
    }
</AppFormField>

@code {
    private readonly string _selectId = $"contact-lookup-{Guid.NewGuid():N}";
    private readonly Dictionary<string, string> _labels = new(StringComparer.Ordinal);
    private bool _showQuickCreate;
    private QuickContactModel _quick = new();

    [Parameter] public string Label { get; set; } = "Liên hệ";
    [Parameter] public bool Required { get; set; }
    [Parameter] public string PlaceHolder { get; set; } = "Tìm liên hệ theo tên, email hoặc điện thoại...";
    [Parameter] public string? CustomerId { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public bool HasError { get; set; }
    [Parameter] public string? ErrorText { get; set; }

    private bool HasCustomer => Guid.TryParse(CustomerId, out _);

    private string? SelectedContactId
    {
        get => Value;
        set => _ = ValueChanged.InvokeAsync(value);
    }

    protected override async Task OnParametersSetAsync()
    {
        await EnsureSelectedLabelAsync();
    }

    private async Task EnsureSelectedLabelAsync()
    {
        if (!Guid.TryParse(Value, out var contactId) || _labels.ContainsKey(Value!))
        {
            return;
        }

        try
        {
            var contact = await CrmApi.GetContactAsync(contactId);
            _labels[Value!] = contact is null ? Value! : FormatContactLabel(contact);
        }
        catch
        {
            _labels[Value!] = Value!;
        }
    }

    private async Task<QueryData<SelectedItem>> QueryContactsAsync(VirtualizeQueryOption option)
    {
        if (!Guid.TryParse(CustomerId, out var customerId))
        {
            return new QueryData<SelectedItem> { Items = [], TotalCount = 0 };
        }

        try
        {
            var result = await CrmApi.GetContactsAsync(new ContactListQuery
            {
                CustomerId = customerId,
                Search = option.SearchText,
                SkipCount = option.StartIndex,
                MaxResultCount = Math.Max(option.Count, 20)
            });

            var items = (result?.Items ?? []).Select(c =>
            {
                var label = FormatContactLabel(c);
                _labels[c.Id.ToString()] = label;
                return new SelectedItem(c.Id.ToString(), label);
            }).ToList();

            return new QueryData<SelectedItem>
            {
                Items = items,
                TotalCount = (int)(result?.TotalCount ?? items.Count)
            };
        }
        catch
        {
            return new QueryData<SelectedItem> { Items = [], TotalCount = 0 };
        }
    }

    private void ToggleQuickCreate() => _showQuickCreate = !_showQuickCreate;

    private void CancelQuickCreate()
    {
        _showQuickCreate = false;
        _quick = new QuickContactModel();
    }

    private async Task CreateContactAsync()
    {
        if (!Guid.TryParse(CustomerId, out var customerId) || string.IsNullOrWhiteSpace(_quick.FullName))
        {
            await ToastService.Warning("Thiếu thông tin", "Vui lòng chọn khách hàng và nhập họ tên liên hệ.");
            return;
        }

        var contact = await CrmApi.CreateContactAsync(new CreateContactRequest(
            customerId,
            _quick.FullName.Trim(),
            _quick.Email,
            _quick.Phone,
            null,
            _quick.Position,
            null,
            false,
            false,
            null));

        if (contact is null)
        {
            return;
        }

        var id = contact.Id.ToString();
        var label = FormatContactLabel(contact);
        _labels[id] = label;
        await ValueChanged.InvokeAsync(id);
        _showQuickCreate = false;
        _quick = new QuickContactModel();
        await ToastService.Success("Thành công", "Đã tạo và chọn liên hệ.");
    }

    private string SelectedContactLabel(SelectedItem? item)
    {
        if (!string.IsNullOrWhiteSpace(Value) && _labels.TryGetValue(Value, out var label))
        {
            return label;
        }

        return string.IsNullOrWhiteSpace(item?.Text) ? PlaceHolder : item.Text;
    }

    private static string FormatContactLabel(ContactDto contact) =>
        $"{contact.FullName} — {contact.Email ?? contact.Phone ?? contact.Position ?? "liên hệ"}";

    private RenderFragment<SelectedItem> RenderSelectedContact => item =>
    @<span class="lookup-selected">@SelectedContactLabel(item)</span>;

    private sealed class QuickContactModel
    {
        public string FullName { get; set; } = "";
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Position { get; set; }
    }
}
