      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "expr": "up{job=\"nexus-services\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Service availability (Prometheus scrape)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"nexus-services\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "HTTP request rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"nexus-services\"}[5m])) by (le, service))",
          "legendFormat": "{{service}} p95",
          "refId": "A"
        }
      ],
      "title": "HTTP latency p95",
      "type": "timeseries"
    }
