{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/identity" } ]
      },
      "tenant": {
        "ClusterId": "tenant",
        "Match": { "Path": "/tenant/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/tenant" } ]
      },
      "permission": {
        "ClusterId": "permission",
        "Match": { "Path": "/permission/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/permission" } ]
      },
      "audit": {
        "ClusterId": "audit",
        "Match": { "Path": "/audit/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/audit" } ]
      },
      "file": {
        "ClusterId": "file",
        "Match": { "Path": "/file/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/file" } ]
      },
      "numbering": {
        "ClusterId": "numbering",
        "Match": { "Path": "/numbering/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/numbering" } ]
      },
      "workflow": {
        "ClusterId": "workflow",
        "Match": { "Path": "/workflow/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/workflow" } ]
      },
      "crm": {
        "ClusterId": "crm",
        "Match": { "Path": "/crm/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/crm" } ]
      },
      "sales": {
        "ClusterId": "sales",
        "Match": { "Path": "/sales/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/sales" } ]
      },
      "notification": {
        "ClusterId": "notification",
        "Match": { "Path": "/notification/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/notification" } ]
      }
    },
    "Clusters": {
      "identity": { "Destinations": { "d1": { "Address": "http://localhost:7202" } } },
      "tenant": { "Destinations": { "d1": { "Address": "http://localhost:7201" } } },
      "permission": { "Destinations": { "d1": { "Address": "http://localhost:7203" } } },
      "audit": { "Destinations": { "d1": { "Address": "http://localhost:7204" } } },
      "file": { "Destinations": { "d1": { "Address": "http://localhost:7205" } } },
      "numbering": { "Destinations": { "d1": { "Address": "http://localhost:7206" } } },
      "workflow": { "Destinations": { "d1": { "Address": "http://localhost:7207" } } },
      "crm": { "Destinations": { "d1": { "Address": "http://localhost:7208" } } },
      "sales": { "Destinations": { "d1": { "Address": "http://localhost:7209" } } },
      "notification": { "Destinations": { "d1": { "Address": "http://localhost:7210" } } }
    }
  }
}
